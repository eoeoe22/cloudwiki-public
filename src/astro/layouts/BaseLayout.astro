---
// 정적 셸 공유 레이아웃.
// 브랜딩·CDN 번들·파비콘·레이아웃 모드를 빌드 타임에 wrangler.toml 값으로 인라인(베이킹)한다.
// 그 결과 Astro 셸은 런타임 HTMLRewriter(브랜딩 치환·번들 주입) 개입 없이 ASSETS 가 즉시 서빙한다.
//  - headTags.prepend(폰트/Bootstrap CSS)는 /css/style.css 보다 먼저 와야 로컬 CSS 가 정상 덮어쓴다.
//  - headTags.append(importmap/Turnstile)는 head 끝, bodyScripts(Bootstrap JS 등)는 body 끝(슬롯 스크립트 뒤).
//  - CUSTOM_HEADER 는 /w/ 하위(revisions·discussions)에서만 인라인(injectCustomHeader) — 런타임 동작과 동일.
import { PAGE_BUNDLES, renderHeadTags, renderBodyScripts } from '../../shared/cdn';
import type { BundleName } from '../../shared/cdn';
import { readBranding } from '../../../scripts/branding.mjs';
import { resolveThemeCss } from '../../../scripts/themes/index.mjs';

interface Props {
    title: string;
    lang?: string;
    pagePath: string;             // PAGE_BUNDLES 조회 키 (예: '/search.html')
    injectCustomHeader?: boolean; // CUSTOM_HEADER 를 body 끝에 인라인할지
}
const { title, lang = 'ko', pagePath, injectCustomHeader = false } = Astro.props;

const branding = readBranding();
const bundles: BundleName[] = PAGE_BUNDLES[pagePath] ?? ['base'];
const headTags = renderHeadTags(bundles);
const bodyScripts = renderBodyScripts(bundles);
const bakedTitle = title.replace(/CloudWiki/g, branding.wikiName).replace(/Cloudwiki/g, branding.wikiName);
const customHeader = injectCustomHeader ? branding.customHeader : '';
// 컬러 테마 스킨: WIKI_THEME 이 가리키는 스킨의 토큰 오버라이드 CSS.
// "default"(기본)면 빈 문자열 → 베이킹 없음(= style.css 그대로, 무변화).
const themeCss = resolveThemeCss(branding.theme);
---
<!DOCTYPE html>
<html lang={lang}>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Fragment set:html={headTags.prepend} />
    <title class="app-wiki-name">{bakedTitle}</title>
    <link rel="icon" id="wiki-favicon" href={branding.wikiFaviconUrl} />
    <link rel="stylesheet" href="/css/style.css" />
    {themeCss && <style is:inline data-wiki-theme={branding.theme} set:html={themeCss}></style>}
    <slot name="head" />
    <Fragment set:html={headTags.append} />
</head>

<body data-layout-mode={branding.layoutMode} style="-webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;">
    <!-- 레이아웃 모드 사용자 오버라이드 FOUC 방지: 파싱 중 즉시 적용(common.ts applyLayoutOverride 와 동일 키). -->
    <script is:inline>try{var m=localStorage.getItem('layoutModeOverride');if(m&&['default','left-toc','right-toc','docs','wide'].indexOf(m)>=0)document.body.setAttribute('data-layout-mode',m);}catch(e){}</script>
    <slot />
    <slot name="scripts" />
    <Fragment set:html={bodyScripts} />
    {customHeader && <Fragment set:html={customHeader} />}
</body>

</html>
