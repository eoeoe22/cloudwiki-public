---
// 위키 문서 조회 및 메인 랜딩 셸. 기존 public/index.html 과 동일한 마커/구조를 유지하되,
// header/sidebar/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// 단, 이 셸은 요청별 데이터(문서별 _ssrTitle/og/_usedPalettes/#ssr-data, CUSTOM_HEADER)가 있어
// src/index.ts 의 renderHtml→applyPageSSR(ASTRO_SHELL_PAGES) 경로로 런타임 주입된다.
// 따라서 head 의 og/description 메타와 본문 H1 의 .app-wiki-name 은 런타임 치환을 위한
// 리터럴 placeholder("CloudWiki")로 둔다. (베이킹하면 applyPageSSR 의 부분문자열 치환이
// 이미 베이킹된 값에 다시 적용돼 'My CloudWiki' 같은 이름에서 'My My CloudWiki' 로 중복됨.)
// CDN 번들(base/markdown)은 BaseLayout 이 PAGE_BUNDLES['/index.html'] 기준으로 베이킹.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/index.html" title="CloudWiki">
    <Fragment slot="head">
        <meta name="description" content="CloudWiki" />
        <meta property="og:title" content="CloudWiki" />
        <meta property="og:description" content="CloudWiki" />
        <meta property="og:site_name" content="CloudWiki" />
        <meta property="og:type" content="website" />
        <link rel="stylesheet" href="/render.css" />
        <link rel="stylesheet" href="/css/wiki-nav.css" />
        <link rel="stylesheet" href="/css/bulk-modal.css" />
        <link rel="stylesheet" href="/css/presentation.css" />
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

  <!-- SPA 네비게이션 프로그레스 바 -->
  <div id="spaProgressBar" class="spa-progress-bar d-none">
    <div class="spa-progress-bar-inner"></div>
  </div>

  <!-- ── 네비게이션 바 ── -->
  <Header />

  <!-- ── 메인 레이아웃 ── -->
  <div class="wiki-layout wiki-layout-doc">
    <!-- 좌측 그룹 문서 트리 (LAYOUT_MODE="docs" 에서만 노출, 문서 조회 페이지 한정) -->
    <aside class="wiki-nav-sidebar d-none" id="wikiNavSidebar" aria-label="문서 그룹 탐색">
      <div class="wiki-toc-sidebar-inner">
        <nav class="wiki-toc-sidebar-nav wiki-nav-sidebar-tree" id="wikiNavSidebarTree"></nav>
      </div>
    </aside>
    <!-- 좌측 목차 사이드바 (LAYOUT_MODE="left-toc" 에서만 노출, 문서 조회 페이지 한정) -->
    <aside class="wiki-toc-sidebar d-none" id="wikiTocSidebar" aria-label="문서 목차">
      <div class="wiki-toc-sidebar-inner">
        <div class="wiki-toc-sidebar-title"><i class="bi bi-list-columns-reverse"></i> 목차</div>
        <nav class="wiki-toc-sidebar-nav" id="wikiTocSidebarNav"></nav>
      </div>
    </aside>
    <!-- 메인 콘텐츠 -->
    <div class="wiki-container">
      <!-- 초기 로딩 (페이지 새로고침/최초 방문) -->
      <div id="loading" class="wiki-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <span>불러오는 중...</span>
      </div>

      <!-- 홈(환영 페이지) -->
      <div id="homePage" class="d-none">
        <div class="wiki-welcome">
          <h1><span class="app-wiki-name">CloudWiki</span></h1>
          <button class="btn btn-wiki" onclick="goNewPage()">
            <i class="bi bi-pencil-square"></i> 첫 문서 만들기
          </button>
        </div>
        <div class="recent-pages-section" id="recentPages"></div>
      </div>

      <!-- 문서 보기 페이지 -->
      <div id="articlePage" class="d-none">
        <!-- 토론 진행 중 배너 -->
        <div id="discussionBanner"
          class="d-none alert alert-warning py-2 px-3 mb-3 d-flex align-items-center justify-content-between">
          <span><i class="bi bi-chat-dots-fill me-2"></i>현재 이 문서에 대한 토론이 진행중입니다.</span>
          <a id="discussionBannerLink" href="#" class="btn btn-sm btn-warning ms-3">
            <i class="bi bi-arrow-right-circle"></i> 토론 보기
          </a>
        </div>

        <!-- 정책 문서(이용약관/개인정보처리방침) 안내 배너 -->
        <div id="policyDocBanner"
          class="d-none alert alert-info py-2 px-3 mb-3 d-flex align-items-center">
          <span><i class="bi bi-info-circle-fill me-2"></i><span id="policyDocBannerText"></span></span>
        </div>

        <div class="wiki-article">
          <h1 class="wiki-article-title" id="articleTitle"></h1>
          <!-- 대체 title 이 설정된 경우만 노출 — 좌측 정렬, muted 작은 글씨로 실제 슬러그 + 복사 버튼 표시 -->
          <div id="articleSlugLabel" class="wiki-article-slug-label" hidden></div>
          <div id="redirectMessage"></div>
          <div class="wiki-article-meta" id="articleMeta"></div>

          <!-- MCP 편집 승인 대기 배너 (로그인 유저 본인 제출안에 한해 노출) -->
          <div id="mcpSubmissionBanner" style="display:none;"></div>

          <!-- 문서 도구 -->
          <div class="d-flex justify-content-end mb-2 gap-2">
            <div class="btn-group" id="articleMainActions">
              <!-- 자바스크립트로 채워짐: 편집, 이력, 토론 -->
            </div>
            <div class="dropdown">
              <button class="btn btn-secondary dropdown-toggle no-caret" type="button" id="shareDropdown"
                data-bs-toggle="dropdown" data-bs-display="static" data-bs-flip="false" aria-expanded="false"
                title="공유하기">
                <i class="bi bi-share"></i>
              </button>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="shareDropdown">
                <li><button class="dropdown-item" onclick="shareNative()">
                    <i class="bi bi-share"></i> 공유하기
                  </button></li>
                <li>
                  <hr class="dropdown-divider">
                </li>
                <li><button class="dropdown-item" onclick="shareCopyLink()">
                    <i class="bi bi-link"></i> 링크 복사하기
                  </button></li>
                <li id="shareItemCopyText"><button class="dropdown-item" onclick="shareCopyText()">
                    <i class="bi bi-copy"></i> 문서 텍스트 복사
                  </button></li>
                <li id="shareItemCopyMarkdown"><button class="dropdown-item" onclick="shareCopyMarkdown()">
                    <i class="bi bi-markdown"></i> 문서 복사 (마크다운)
                  </button></li>
                <li id="shareItemPrint"><button class="dropdown-item" onclick="sharePrint()">
                    <i class="bi bi-printer"></i> 인쇄하기
                  </button></li>
                <li id="shareAiDivider">
                  <hr class="dropdown-divider">
                </li>
                <li id="shareItemAskClaude"><button class="dropdown-item" onclick="shareAskClaude()">
                    <i class="bi bi-claude"></i> Claude에게 질문하기
                  </button></li>
                <li id="shareItemAskChatGPT"><button class="dropdown-item" onclick="shareAskChatGPT()">
                    <i class="bi bi-openai"></i> ChatGPT에게 질문하기
                  </button></li>
              </ul>
            </div>
            <div class="dropdown">
              <button class="btn btn-secondary dropdown-toggle no-caret" type="button" id="docToolsDropdown"
                data-bs-toggle="dropdown" data-bs-display="static" data-bs-flip="false" aria-expanded="false"
                title="문서 도구">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="docToolsDropdown" id="articleMoreActions">
                <!-- 자바스크립트로 채워짐 -->
              </ul>
            </div>
          </div>

          <!-- 상위 문서 (하위 문서인 경우) -->
          <div id="parentDocsNavWrapper" class="parent-docs-nav-wrapper">
            <div id="parentDocsNav" class="d-none parent-docs-nav mb-0"></div>
            <div id="parentDocsSiblings" class="d-none parent-docs-siblings"></div>
          </div>
          <hr id="parentDocsNavDivider" class="d-none mt-2 mb-3">

          <!-- 목차 아코디언 -->
          <div class="accordion mb-4" id="wikiAccordion">
            <!-- 목차: 본문 상단 인라인 카드(.wiki-toc-card)로 대체되어 영구 숨김.
                 #tocNav 는 플로팅 패널 / 스크롤 스파이 / FAB / 인라인 카드 클론의
                 데이터 소스로 계속 사용되므로 DOM 에는 유지한다. -->
            <div class="accordion-item d-none">
              <h2 class="accordion-header" id="headingTOC">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                  data-bs-target="#collapseTOC" aria-expanded="false" aria-controls="collapseTOC">
                  <i class="bi bi-list-columns-reverse me-2"></i> 목차
                </button>
              </h2>
              <div id="collapseTOC" class="accordion-collapse collapse" aria-labelledby="headingTOC"
                data-bs-parent="#wikiAccordion">
                <div class="accordion-body">
                  <div id="tocContainer" class="d-none">
                    <nav id="tocNav"></nav>
                  </div>
                </div>
              </div>
            </div>
            <div id="docStatsCounter" class="doc-stats-counter d-none" aria-live="off">
              <span data-counter="lines">0줄</span>
              <span data-counter="chars">0자</span>
              <span data-counter="charsWithSpaces">0자(공백포함)</span>
              <span data-counter="words">0단어</span>
            </div>
          </div>

          <!-- 본문 -->
          <div class="wiki-content" id="articleContent"></div>

          <!-- 본문 (Raw 보기) -->
          <pre class="wiki-content-raw" id="articleRawContent"></pre>

          <!-- 백링크 -->
          <div class="backlinks-section d-none" id="backlinksSection">
            <h5><i class="bi bi-link-45deg"></i> 이 문서를 참조하는 문서</h5>
            <div class="list-group" id="backlinksList"></div>
          </div>

          <!-- 이전/다음 문서 (LAYOUT_MODE="docs" 에서만 노출, 그룹 트리 순서 기준) -->
          <nav class="docs-page-nav d-none" id="docsPageNav" aria-label="이전/다음 문서"></nav>
        </div>
      </div>

      <!-- 문서 없음 -->
      <div id="notFoundPage" class="d-none">
        <div class="wiki-not-found">
          <h2><span class="mdi mdi-file-document-alert"></span> 문서가 없습니다</h2>
          <p id="notFoundSlug"></p>
          <button class="btn btn-wiki" id="createPageBtn">
            <i class="bi bi-plus-lg"></i> 이 문서 만들기
          </button>
        </div>
      </div>

      <!-- 삭제된 문서 -->
      <div id="deletedPage" class="d-none">
        <div class="wiki-not-found">
          <h2><span class="mdi mdi-delete-empty text-danger"></span> 삭제된 문서입니다</h2>
          <p id="deletedSlug"></p>
        </div>
      </div>

      <!-- 비공개 문서 -->
      <div id="privatePage" class="d-none">
        <div class="wiki-not-found">
          <h2><span class="bi bi-eye-slash-fill text-danger"></span> 비공개 문서입니다</h2>
          <p id="privateSlug"></p>
          <p class="text-muted small">이 문서는 비공개로 설정되어 권한이 있는 사용자만 열람할 수 있습니다.</p>
        </div>
      </div>

      <!-- 카테고리 문서 목록 -->
      <div id="categoryPage" class="d-none">
        <div class="wiki-article">
          <h2><i class="bi bi-folder2-open"></i> 카테고리: <span id="catPageTitle"></span></h2>
          <div class="list-group mt-4" id="categoryDocsList"></div>
        </div>
      </div>

    </div> <!-- wiki-container end -->

    <!-- 우측 문서내 목차 사이드바 (LAYOUT_MODE="docs" 또는 "right-toc" 에서 노출, 문서 조회 페이지 한정) -->
    <aside class="wiki-toc-sidebar wiki-toc-sidebar-right d-none" id="wikiTocSidebarRight" aria-label="문서 목차">
      <div class="wiki-toc-sidebar-inner">
        <nav class="wiki-toc-sidebar-nav" id="wikiTocSidebarRightNav"></nav>
      </div>
    </aside>

    <!-- 오른쪽 사이드바 (PC 전용 오프캔버스 컨테이너 및 최근 변경) -->
    <aside class="wiki-sidebar" id="wikiSidebar">
      <!-- 사이드바 네비게이션 (모바일 오프캔버스 렌더링 영역 공유) -->
      <Sidebar />

      <!-- 실시간 트렌딩 -->
      <div class="mb-4">

        <div class="sidebar-section">
          <h6 class="sidebar-title d-flex justify-content-between align-items-center mb-2">
            <span><i class="bi bi-graph-up-arrow text-danger"></i> 실시간 트렌딩</span>
            <a href="#" class="small text-muted text-decoration-none trending-expand-btn" style="font-size: 0.8rem;">펼치기
              <i class="bi bi-chevron-down"></i></a>
          </h6>
          <div class="position-relative overflow-hidden trending-ticker-wrapper" style="height: 38px;">
            <div id="trendingListPc" class="trending-container trending-ticker-list">
              <div class="placeholder-glow px-2 py-2">
                <span class="placeholder w-100 d-block" style="height: 1.5rem; border-radius: 4px;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 최근 변경 -->
      <div class="mb-4">
        <div class="sidebar-section">
          <h6 class="sidebar-title"><i class="bi bi-clock-history"></i> 최근 변경</h6>
          <div id="recentChangesListPc" class="recent-changes-list recent-changes-container">
            <div class="placeholder-glow">
              <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
              <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
              <span class="placeholder w-100 d-block" style="height: 2.5rem; border-radius: 6px;"></span>
            </div>
          </div>
        </div>
      </div>

    </aside>
  </div> <!-- wiki-layout end -->

  <!-- ── 푸터 ── -->
  <Footer />

  <!-- 플로팅 목차 패널 -->
  <div class="toc-floating-panel" id="tocFloatingPanel">
    <div class="toc-floating-header">
      <span><i class="mdi mdi-format-list-bulleted-square me-1"></i> 목차</span>
      <button class="toc-floating-close" onclick="toggleFloatingToc()" title="닫기">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
    <nav class="toc-floating-body" id="tocFloatingNav"></nav>
  </div>

  <!-- 스크롤 FAB (뷰포트 고정, body 직전) -->
  <div class="scroll-fab-group" id="scrollFabGroup">
    <button class="scroll-fab reading-mode-exit-fab d-none" id="readingModeExitFab" onclick="toggleReadingMode()"
      title="읽기 모드 나가기" aria-label="읽기 모드 나가기">
      <i class="bi bi-x-lg"></i>
    </button>
    <button class="scroll-fab raw-mode-exit-fab d-none" id="rawModeExitFab" onclick="toggleRawMode()" title="Raw 보기 나가기"
      aria-label="Raw 보기 나가기">
      <i class="bi bi-x-lg"></i>
    </button>
    <button class="scroll-fab" id="tocFabBtn" onclick="toggleFloatingToc()" title="목차">
      <i class="mdi mdi-format-list-bulleted-square"></i>
    </button>
    <button class="scroll-fab" id="scrollToTopBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="맨 위로">
      <i class="bi bi-chevron-up"></i>
    </button>
    <button class="scroll-fab" id="scrollToBottomBtn"
      onclick="window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'})" title="맨 아래로">
      <i class="bi bi-chevron-down"></i>
    </button>
  </div>

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/render.js" is:inline></script>
        <script type="module" src="/dist/render-presentation.js" is:inline></script>
        <script type="module" src="/dist/permissions-modal.js" is:inline></script>
        <script type="module" src="/dist/category-acl-modal.js" is:inline></script>
        <script type="module" src="/dist/index.js" is:inline></script>
    </Fragment>
</BaseLayout>
