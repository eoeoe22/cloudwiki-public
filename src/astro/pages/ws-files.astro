---
// 워크스페이스 파일(문서) 탐색기 셸 (/ws/:wslug/files).
// wslug 는 클라이언트(ws-files.ts)가 location.pathname 에서 파싱한다.
// search.astro / ws-dashboard.astro 와 동일한 구조를 따른다.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/ws-files.html" title="파일 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <!-- 툴바: 브레드크럼 + 새 문서 버튼 -->
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/workspaces"><i class="bi bi-grid"></i> 워크스페이스</a></li>
                            <li class="breadcrumb-item" id="bcrWs">
                                <a href="#" id="bcrWsLink"><span id="bcrWsName">...</span></a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">파일</li>
                        </ol>
                    </nav>
                    <button type="button" class="btn btn-wiki-outline btn-sm" id="btnNewDoc" onclick="window.wsFileNew()">
                        <i class="bi bi-file-earmark-plus"></i> 새 문서
                    </button>
                </div>

                <!-- 로딩 -->
                <div id="wsFilesLoading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>불러오는 중...</span>
                </div>

                <!-- 오류 -->
                <div id="wsFilesError" class="d-none">
                    <div class="empty-state">
                        <i class="empty-state-icon bi bi-exclamation-triangle" aria-hidden="true"></i>
                        <p class="empty-state-title" id="wsFilesErrorTitle">파일을 불러올 수 없습니다</p>
                        <p class="empty-state-text">워크스페이스에 접근하는 중 문제가 발생했습니다.</p>
                        <div class="empty-state-cta">
                            <a href="/workspaces" class="btn btn-wiki btn-sm"><i class="bi bi-arrow-left"></i> 내 워크스페이스로</a>
                        </div>
                    </div>
                </div>

                <!-- 빈 상태 (문서 없음) -->
                <div id="wsFilesEmpty" class="d-none">
                    <div class="empty-state">
                        <i class="empty-state-icon bi bi-file-earmark" aria-hidden="true"></i>
                        <p class="empty-state-title">아직 문서가 없습니다</p>
                        <p class="empty-state-text">워크스페이스의 첫 번째 문서를 만들어 보세요.</p>
                        <div class="empty-state-cta">
                            <button type="button" class="btn btn-wiki btn-sm" onclick="window.wsFileNew()">
                                <i class="bi bi-file-earmark-plus"></i> 첫 문서 만들기
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 파일 트리 -->
                <div id="wsFileTree" class="d-none"></div>

            </div>
        </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/ws-files.js" is:inline></script>
    </Fragment>
</BaseLayout>
