---
// 검색 결과 페이지 셸. 기존 public/search.html 과 동일한 마커/구조를 유지하되,
// header/sidebar/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// base CDN(Bootstrap 등)은 BaseLayout 이 빌드 타임에 인라인(베이킹) — PAGE_BUNDLES['/search.html']=['base']기준으로 베이킹.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/search.html" title="검색 결과 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <h2 class="mb-0" id="searchTitle">
                        <i class="mdi mdi-magnify"></i> 검색 결과
                    </h2>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-wiki-outline btn-sm" onclick="history.back()">
                            <i class="bi bi-arrow-left"></i> 뒤로
                        </button>
                    </div>
                </div>
                <p class="text-muted mb-2" id="searchQuery"></p>

                <!-- 네임스페이스 칩 (모든 검색 모드 공통) -->
                <div class="search-namespace-chips d-flex flex-wrap gap-2 mb-3" id="namespaceChips">
                    <button type="button" class="search-chip" data-ns="doc" onclick="goDocumentSearch()">
                        <i class="mdi mdi-file-document-outline"></i> 문서
                    </button>
                    <button type="button" class="search-chip" data-ns="image" onclick="goImageSearch()">
                        <i class="mdi mdi-image-search-outline"></i> 이미지
                    </button>
                    <button type="button" class="search-chip" data-ns="category" onclick="goCategorySearch()">
                        <i class="mdi mdi-folder-search-outline"></i> 카테고리
                    </button>
                </div>

                <!-- 필터 바 (일반 문서 검색 모드 전용 — search.ts 가 모드에 따라 표시/숨김) -->
                <div class="search-filters card card-body mb-4 d-none" id="searchFilters">
                    <div class="row g-2 align-items-end">
                        <div class="col-6 col-md-auto">
                            <label class="form-label small mb-1" for="sortSelect">정렬</label>
                            <select id="sortSelect" class="form-select form-select-sm" onchange="onFilterChange()">
                                <option value="relevance">관련도순</option>
                                <option value="recent">최신순</option>
                                <option value="title">제목순</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-auto">
                            <label class="form-label small mb-1" for="fieldSelect">검색 범위</label>
                            <select id="fieldSelect" class="form-select form-select-sm" onchange="onFilterChange()">
                                <option value="all">제목+본문</option>
                                <option value="title">제목만</option>
                                <option value="body">본문만</option>
                            </select>
                        </div>
                        <div class="col-12 col-md">
                            <label class="form-label small mb-1" for="categoryFilter">카테고리</label>
                            <input type="text" id="categoryFilter" class="form-control form-control-sm" placeholder="정확한 카테고리명" autocomplete="off" onchange="onFilterChange()">
                            <!-- 카테고리 자동완성 드롭다운 (에디터 #category-autocomplete 과 동일 방식 — position:fixed 라 JS 가 입력칸 기준으로 좌표/너비를 잡는다) -->
                            <div id="searchCategoryAutocomplete" class="list-group"></div>
                        </div>
                        <div class="col-6 col-md-auto">
                            <label class="form-label small mb-1" for="fromDate">시작일</label>
                            <input type="date" id="fromDate" class="form-control form-control-sm" onchange="onFilterChange()">
                        </div>
                        <div class="col-6 col-md-auto">
                            <label class="form-label small mb-1" for="toDate">종료일</label>
                            <input type="date" id="toDate" class="form-control form-control-sm" onchange="onFilterChange()">
                        </div>
                        <div class="col-12 col-md-auto d-none" id="includePrivateWrap">
                            <div class="form-check mb-1 mb-md-2">
                                <input class="form-check-input" type="checkbox" id="includePrivate" checked onchange="onFilterChange()">
                                <label class="form-check-label small" for="includePrivate">비공개 포함</label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-wiki-outline btn-sm" id="resetFilters" onclick="resetFilters()">
                                <i class="bi bi-x-circle"></i> 초기화
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 로딩 -->
                <div id="loading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>검색 중...</span>
                </div>

                <!-- 결과 없음 -->
                <!-- 내용은 search.ts 의 setNoResultsState() 가 표준 빈 상태(.empty-state)로 채운다 -->
                <div id="noResults" class="d-none">
                    <div class="empty-state">
                        <i class="empty-state-icon bi bi-search" aria-hidden="true"></i>
                        <p class="empty-state-title">검색 결과가 없습니다</p>
                        <p class="empty-state-text">다른 키워드로 검색해 보세요.</p>
                    </div>
                </div>

                <!-- 결과 목록 -->
                <div id="resultsList"></div>

                <!-- 모바일 최근 변경 (모바일 전용) -->
                <div class="mt-4 d-lg-none">
                    <div class="sidebar-section">
                        <h6 class="sidebar-title"><a href="/explore#docActivity" class="text-decoration-none text-reset"><i
                                    class="bi bi-clock-history"></i> 최근 변경</a></h6>
                        <div class="recent-changes-list recent-changes-container"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 오른쪽 사이드바 (PC 전용 오프캔버스 컨테이너) -->
        <aside class="wiki-sidebar" id="wikiSidebar">
            <Sidebar />
        </aside>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/search.js" is:inline></script>
    </Fragment>
</BaseLayout>
