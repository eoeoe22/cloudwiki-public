---
// 검색 결과 페이지 셸. 기존 public/search.html 과 동일한 마커/구조를 유지하되,
// header/sidebar/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// base CDN(Bootstrap 등)은 BaseLayout 이 빌드 타임에 인라인(베이킹) — PAGE_BUNDLES['/search.html']=['base']기준으로 베이킹.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/search.html" title="검색 결과 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <h2 class="mb-0" id="searchTitle">
                        <i class="mdi mdi-magnify"></i> 검색 결과
                    </h2>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-wiki-outline btn-sm" id="imageSearchBtn" onclick="goImageSearch()" title="이미지 검색하기" aria-label="이미지 검색하기">
                            <i class="mdi mdi-image-search-outline"></i>
                        </button>
                        <button type="button" class="btn btn-wiki-outline btn-sm" id="categorySearchBtn" onclick="goCategorySearch()" title="카테고리 검색하기" aria-label="카테고리 검색하기">
                            <i class="mdi mdi-folder-search-outline"></i>
                        </button>
                        <button type="button" class="btn btn-wiki-outline btn-sm" onclick="history.back()">
                            <i class="bi bi-arrow-left"></i> 뒤로
                        </button>
                    </div>
                </div>
                <p class="text-muted mb-4" id="searchQuery"></p>

                <!-- 로딩 -->
                <div id="loading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>검색 중...</span>
                </div>

                <!-- 결과 없음 -->
                <div id="noResults" class="d-none text-center py-5">
                    <h4 class="text-muted">검색 결과가 없습니다</h4>
                    <p class="text-muted">다른 키워드로 검색해 보세요.</p>
                </div>

                <!-- 결과 목록 -->
                <div id="resultsList"></div>

                <!-- 모바일 최근 변경 (모바일 전용) -->
                <div class="mt-4 d-lg-none">
                    <div class="sidebar-section">
                        <h6 class="sidebar-title"><a href="/recent-changes" class="text-decoration-none text-reset"><i
                                    class="bi bi-clock-history"></i> 최근 변경</a></h6>
                        <div class="recent-changes-list recent-changes-container"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 오른쪽 사이드바 (PC 전용 오프캔버스 컨테이너) -->
        <aside class="wiki-sidebar" id="wikiSidebar">
            <Sidebar />
        </aside>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/search.js" is:inline></script>
    </Fragment>
</BaseLayout>
