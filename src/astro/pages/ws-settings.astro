---
// 워크스페이스 설정 셸 (/ws/:wslug/settings). search.astro 와 동일한 구조를 따른다.
// canManage 가 아닌 사용자는 ws-settings.ts 가 안내 후 대시보드로 돌려보낸다.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/ws-settings.html" title="워크스페이스 설정 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <!-- 로딩 -->
                <div id="wsLoading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>불러오는 중...</span>
                </div>

                <!-- 본문 -->
                <div id="wsContent" class="d-none">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h2 class="mb-0"><i class="bi bi-gear"></i> <span id="wsSettingsTitle">워크스페이스 설정</span></h2>
                        <a href="#" class="btn btn-wiki-outline btn-sm" id="backToWsBtn"><i class="bi bi-arrow-left"></i> 대시보드</a>
                    </div>

                    <!-- 1. 참가자 관리 -->
                    <div class="card mb-4">
                        <div class="card-header"><i class="bi bi-people"></i> 참가자 관리</div>
                        <div class="card-body" id="membersManage"></div>
                    </div>

                    <!-- 2. 초대 -->
                    <div class="card mb-4">
                        <div class="card-header"><i class="bi bi-person-plus"></i> 멤버 초대</div>
                        <div class="card-body">
                            <div class="row g-2 align-items-end mb-2">
                                <div class="col-12 col-md">
                                    <label class="form-label small mb-1" for="inviteSearch">사용자 검색</label>
                                    <input type="text" id="inviteSearch" class="form-control form-control-sm" placeholder="닉네임으로 검색" autocomplete="off" oninput="onInviteSearch()">
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-1" for="inviteRole">역할</label>
                                    <select id="inviteRole" class="form-select form-select-sm">
                                        <option value="viewer">viewer (읽기)</option>
                                        <option value="editor">editor (편집)</option>
                                    </select>
                                </div>
                            </div>
                            <div id="inviteResults" class="list-group"></div>
                        </div>
                    </div>

                    <!-- 3. 소유권 이전 -->
                    <div class="card mb-4">
                        <div class="card-header"><i class="bi bi-arrow-left-right"></i> 소유권 이전</div>
                        <div class="card-body">
                            <p class="text-muted small">현재 멤버 중 한 명에게 소유권을 이전합니다. 이전 후 본인은 editor 로 강등됩니다.</p>
                            <div class="row g-2 align-items-end">
                                <div class="col-12 col-md">
                                    <select id="transferTarget" class="form-select form-select-sm"></select>
                                </div>
                                <div class="col-auto">
                                    <button type="button" class="btn btn-wiki btn-sm" onclick="doTransfer()">
                                        <i class="bi bi-arrow-left-right"></i> 소유권 이전
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. 워크스페이스 정보 -->
                    <div class="card mb-4">
                        <div class="card-header"><i class="bi bi-info-circle"></i> 워크스페이스 정보</div>
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-12 col-md-6">
                                    <label class="form-label small mb-1" for="wsSlugInput">제목</label>
                                    <input type="text" id="wsSlugInput" class="form-control form-control-sm" maxlength="64">
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label small mb-1" for="wsNameInput">대체 제목</label>
                                    <input type="text" id="wsNameInput" class="form-control form-control-sm" maxlength="100">
                                </div>
                            </div>
                            <div class="mt-3">
                                <label class="form-label small mb-1 d-block">아이콘</label>
                                <button type="button" id="wsIconBtn" class="btn btn-wiki btn-sm" onclick="pickWsIcon()"></button>
                            </div>
                            <div class="mt-3">
                                <button type="button" class="btn btn-wiki btn-sm" onclick="saveWsInfo()">
                                    <i class="bi bi-save"></i> 저장
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- 5. 위험 구역 -->
                    <div class="card border-danger mb-4">
                        <div class="card-header text-danger"><i class="bi bi-exclamation-octagon"></i> 위험 구역</div>
                        <div class="card-body">
                            <p class="text-muted small mb-2">워크스페이스를 삭제하면 소속 문서와 미디어에 접근할 수 없게 됩니다.</p>
                            <button type="button" class="btn btn-wiki btn-wiki-danger btn-sm" onclick="deleteWorkspace()">
                                <i class="bi bi-trash"></i> 워크스페이스 삭제
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 아이콘 피커 모달 (iconPicker.ts 모듈이 사용) — body 레벨에 두어
         Bootstrap 모달이 부모 컨테이너 stacking context 의 영향을 받지 않도록 함. -->
    <div class="modal fade" id="iconPickerModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">
              <i id="iconPickerTypeIcon" class="mdi mdi-material-design me-2"></i>
              <span id="iconPickerTitle">아이콘 선택</span>
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="icon-picker-toolbar mb-2">
              <div class="icon-picker-tabs" role="tablist" aria-label="아이콘 라이브러리">
                <button type="button" id="iconPickerTabMdi" class="icon-picker-tab active" role="tab" aria-selected="true">
                  <i class="mdi mdi-material-design"></i><span>MDI</span>
                </button>
                <button type="button" id="iconPickerTabBi" class="icon-picker-tab" role="tab" aria-selected="false">
                  <i class="bi bi-bootstrap"></i><span>Bootstrap</span>
                </button>
              </div>
              <button type="button" id="iconPickerNoneBtn" class="icon-picker-none-btn">
                <i class="bi bi-x-lg"></i><span>아이콘 없음</span>
              </button>
            </div>
            <input type="text" id="iconSearchInput" class="form-control mb-3" placeholder="아이콘 이름 검색..." />
            <div id="iconLoadingSpinner" class="text-center py-4" style="display: none">
              <span class="spinner-border text-primary" role="status"></span>
              <p class="mt-2 text-muted small">아이콘 목록 로딩 중...</p>
            </div>
            <div id="iconPickerGrid" class="icon-grid-modal"></div>
            <div id="iconPickerEmpty" class="text-center text-muted py-3" style="display: none">
              <i class="mdi mdi-magnify-close" style="font-size: 2rem"></i>
              <p class="mt-1">검색 결과가 없습니다.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/icon-picker.js" is:inline></script>
        <script type="module" src="/dist/ws-settings.js" is:inline></script>
    </Fragment>
</BaseLayout>
