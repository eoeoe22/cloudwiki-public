---
// 편집 이력(리비전) 페이지 셸. 기존 public/revisions.html 과 동일한 마커/구조를 유지하되,
// header/sidebar/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// base CDN 은 BaseLayout 이 빌드 타임에 인라인(베이킹) — PAGE_BUNDLES['/revisions.html']=['base','markdown']기준으로 베이킹.
// render.css/diff.css 는 위키 본문/diff 렌더링용으로 head 슬롯에서 직접 로드.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/revisions.html" injectCustomHeader title="편집 이력 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
        <link rel="stylesheet" href="/render.css" />
        <link rel="stylesheet" href="/css/diff.css" />
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <!-- ── 메인 레이아웃 ── -->
    <div class="wiki-layout">
        <div class="wiki-container">
            <!-- 로딩 -->
            <div id="loading" class="wiki-loading">
                <div class="spinner-border text-primary" role="status"></div>
                <span>불러오는 중...</span>
            </div>

            <!-- 리비전 본문 보기 -->
            <div id="revisionViewPage" class="d-none">
                <div class="alert alert-warning py-2 px-3 mb-0 d-flex align-items-center justify-content-between"
                    style="position: sticky; top: 0; z-index: 100; border-radius: 0; border-left: none; border-right: none; margin-left: calc(-1 * var(--wiki-container-padding, 1.5rem)); margin-right: calc(-1 * var(--wiki-container-padding, 1.5rem));">
                    <span><i class="bi bi-clock-history me-2"></i><strong id="revisionViewLabel"></strong></span>
                    <div class="d-flex gap-2">
                        <button id="rawViewBtn" class="btn btn-sm btn-outline-secondary btn-icon-collapse" onclick="toggleRawView()">
                            <i class="bi bi-code"></i><span class="btn-collapse-text"> Raw</span>
                        </button>
                        <button class="btn btn-sm btn-warning btn-icon-collapse" onclick="backToRevisions()">
                            <i class="bi bi-arrow-left"></i><span class="btn-collapse-text"> 목록으로</span>
                        </button>
                    </div>
                </div>
                <div class="wiki-article">
                    <h1 class="wiki-article-title" id="revisionViewTitle"></h1>
                    <div class="wiki-content" id="revisionViewContent"></div>
                </div>
            </div>

            <!-- 리비전 목록 -->
            <div id="revisionsPage" class="d-none">
                <div class="wiki-article" style="width: 100%; max-width: 100vw; overflow-x: hidden;">
                    <h2 class="text-break"><i class="bi bi-clock-history"></i> 편집 이력: <span id="revPageTitle"></span></h2>
                    <div class="table-responsive"
                        style="width: 100%; max-width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
                        <div class="revision-list" id="revisionsList" style="min-width: 800px; width: max-content;"></div>
                    </div>
                    <nav id="revisionsPagination" class="mt-3 d-none" aria-label="편집 이력 페이지네이션">
                        <ul class="pagination justify-content-center flex-wrap" id="revisionsPaginationList"></ul>
                    </nav>
                    <a id="revBackLink" href="#" class="btn btn-wiki-outline mt-3">
                        <i class="bi bi-arrow-left"></i> 문서로 돌아가기
                    </a>
                </div>
            </div>
        </div>

        <!-- 오른쪽 사이드바 (PC 전용 오프캔버스 컨테이너 및 최근 변경) -->
        <aside class="wiki-sidebar" id="wikiSidebar">
            <Sidebar />

            <!-- 실시간 트렌딩 (PC/모바일 공통) -->
            <div class="mb-4">
                <div class="sidebar-section">
                    <h6 class="sidebar-title d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-graph-up-arrow text-danger"></i> 실시간 트렌딩</span>
                        <a href="#" class="small text-muted text-decoration-none trending-expand-btn" style="font-size: 0.8rem;">펼치기
                            <i class="bi bi-chevron-down"></i></a>
                    </h6>
                    <div class="position-relative overflow-hidden trending-ticker-wrapper" style="height: 38px;">
                        <div id="trendingListPc" class="trending-container trending-ticker-list">
                            <div class="placeholder-glow px-2 py-2">
                                <span class="placeholder w-100 d-block" style="height: 1.5rem; border-radius: 4px;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PC 전용 최근 변경 -->
            <div class="d-none d-lg-block">
                <div class="sidebar-section sidebar-section-pc-only">
                    <h6 class="sidebar-title"><i class="bi bi-clock-history"></i> 최근 변경</h6>
                    <div id="recentChangesListPc" class="recent-changes-list recent-changes-container">
                        <div class="placeholder-glow">
                            <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
                            <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
                            <span class="placeholder w-100 d-block" style="height: 2.5rem; border-radius: 6px;"></span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/render.js" is:inline></script>
        <script type="module" src="/dist/diff.js" is:inline></script>
        <script type="module" src="/dist/revisions.js" is:inline></script>
    </Fragment>
</BaseLayout>
