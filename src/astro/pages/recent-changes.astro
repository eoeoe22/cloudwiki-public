---
// 최근 수정 내역 페이지 셸. 기존 public/recent-changes.html 과 동일한 마커/구조를 유지하되,
// header/sidebar/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// base CDN(Bootstrap 등)은 BaseLayout 이 빌드 타임에 인라인(베이킹) — PAGE_BUNDLES['/recent-changes.html']=['base']기준으로 베이킹.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/recent-changes.html" title="최근 수정 내역 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <!-- ── 메인 레이아웃 ── -->
    <div class="wiki-layout">
        <div class="wiki-container">
            <!-- 로딩 -->
            <div id="loading" class="wiki-loading">
                <div class="spinner-border text-primary" role="status"></div>
                <span>불러오는 중...</span>
            </div>

            <!-- 메인 콘텐츠 -->
            <div id="mainContent" class="d-none">
                <div class="wiki-article" style="width: 100%; max-width: 100vw; overflow-x: hidden;">

                    <!-- 위키 통계 -->
                    <div id="wikiStatsBar" class="d-flex gap-3 mb-3 flex-wrap">
                        <span class="badge bg-primary bg-opacity-10 text-primary border px-3 py-2" style="font-size: 0.9rem;">
                            <i class="bi bi-file-earmark-text"></i> 문서 <strong id="statPageCount">-</strong>개
                        </span>
                        <span class="badge bg-success bg-opacity-10 text-success border px-3 py-2" style="font-size: 0.9rem;">
                            <i class="bi bi-pencil-square"></i> 편집 <strong id="statRevisionCount">-</strong>회
                        </span>
                    </div>

                    <!-- 탭 네비게이션 -->
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="tab-recent" data-bs-toggle="tab" data-bs-target="#pane-recent"
                                type="button" role="tab" aria-selected="true">
                                <i class="bi bi-clock-history"></i> 최근 수정 내역
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-allpages" data-bs-toggle="tab" data-bs-target="#pane-allpages"
                                type="button" role="tab" aria-selected="false">
                                <i class="bi bi-journals"></i> 모든 문서 목록
                            </button>
                        </li>
                    </ul>

                    <!-- 탭 콘텐츠 -->
                    <div class="tab-content">
                        <!-- 최근 수정 내역 탭 -->
                        <div class="tab-pane fade show active" id="pane-recent" role="tabpanel">
                            <div class="table-responsive"
                                style="width: 100%; max-width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
                                <div class="revision-list" id="revisionsList" style="width: max-content; min-width: 100%;"></div>
                            </div>
                            <nav id="recentRevisionsPagination" class="mt-3 d-none" aria-label="최근 수정 내역 페이지네이션">
                                <ul class="pagination justify-content-center flex-wrap" id="recentRevisionsPaginationList"></ul>
                            </nav>
                        </div>

                        <!-- 모든 문서 목록 탭 -->
                        <div class="tab-pane fade" id="pane-allpages" role="tabpanel">
                            <!-- 정렬 드롭다운 -->
                            <div class="d-flex justify-content-end mb-3">
                                <select id="allPagesSortSelect" class="form-select form-select-sm" style="width: auto;"
                                    onchange="changeSort()">
                                    <option value="slug_asc">문서 이름 가나다순</option>
                                    <option value="slug_desc">문서 이름 가나다 역순</option>
                                    <option value="created_desc">생성일 최신순</option>
                                    <option value="created_asc">생성일 오래된순</option>
                                    <option value="updated_desc">마지막 수정 최신순</option>
                                    <option value="updated_asc">마지막 수정 오래된순</option>
                                    <option value="category_asc">카테고리 가나다순</option>
                                    <option value="category_desc">카테고리 가나다 역순</option>
                                    <option value="chars_desc">긴 문서순</option>
                                    <option value="chars_asc">짧은 문서순</option>
                                </select>
                            </div>
                            <!-- 문서 목록 (가로 스크롤 래퍼) -->
                            <div class="table-responsive"
                                style="width: 100%; max-width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
                                <div id="allPagesList" style="min-width: 560px;"></div>
                            </div>
                            <nav id="allPagesPagination" class="mt-3 d-none" aria-label="문서 목록 페이지네이션">
                                <ul class="pagination justify-content-center flex-wrap" id="allPagesPaginationList"></ul>
                            </nav>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- 오른쪽 사이드바 (PC 전용 오프캔버스 컨테이너 및 최근 변경) -->
        <aside class="wiki-sidebar" id="wikiSidebar">
            <Sidebar />

            <!-- 실시간 트렌딩 (PC/모바일 공통) -->
            <div class="mb-4">
                <div class="sidebar-section">
                    <h6 class="sidebar-title d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-graph-up-arrow text-danger"></i> 실시간 트렌딩</span>
                        <a href="#" class="small text-muted text-decoration-none trending-expand-btn" style="font-size: 0.8rem;">펼치기
                            <i class="bi bi-chevron-down"></i></a>
                    </h6>
                    <div class="position-relative overflow-hidden trending-ticker-wrapper" style="height: 38px;">
                        <div id="trendingListPc" class="trending-container trending-ticker-list">
                            <div class="placeholder-glow px-2 py-2">
                                <span class="placeholder w-100 d-block" style="height: 1.5rem; border-radius: 4px;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PC 전용 최근 변경 -->
            <div class="d-none d-lg-block">
                <div class="sidebar-section sidebar-section-pc-only">
                    <h6 class="sidebar-title"><i class="bi bi-clock-history"></i> 최근 변경</h6>
                    <div id="recentChangesListPc" class="recent-changes-list recent-changes-container">
                        <div class="placeholder-glow">
                            <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
                            <span class="placeholder w-100 d-block mb-2" style="height: 2.5rem; border-radius: 6px;"></span>
                            <span class="placeholder w-100 d-block" style="height: 2.5rem; border-radius: 6px;"></span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/recent-changes.js" is:inline></script>
    </Fragment>
</BaseLayout>
