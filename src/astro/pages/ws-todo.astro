---
// 워크스페이스 TODO 리스트 상세 셸 (/ws/:wslug/todos).
// wslug 는 클라이언트(ws-todo.ts)가 location.pathname 에서 파싱한다.
// ws-files.astro / ws-dashboard.astro 와 동일한 구조를 따른다.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/ws-todo.html" title="TODO - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <!-- 로딩 -->
                <div id="todoLoading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>불러오는 중...</span>
                </div>

                <!-- 접근 오류 -->
                <div id="todoError" class="d-none">
                    <div class="empty-state">
                        <i class="empty-state-icon bi bi-exclamation-triangle" aria-hidden="true"></i>
                        <p class="empty-state-title" id="todoErrorTitle">TODO 를 불러올 수 없습니다</p>
                        <p class="empty-state-text">존재하지 않거나 접근 권한이 없는 워크스페이스입니다.</p>
                        <div class="empty-state-cta">
                            <a href="/workspaces" class="btn btn-wiki btn-sm"><i class="bi bi-arrow-left"></i> 내 워크스페이스로</a>
                        </div>
                    </div>
                </div>

                <!-- 본문 -->
                <div id="todoContent" class="d-none">
                    <!-- 브레드크럼 -->
                    <nav aria-label="breadcrumb" class="mb-3">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/workspaces"><i class="bi bi-grid"></i> 워크스페이스</a></li>
                            <li class="breadcrumb-item">
                                <a href="#" id="bcrWsLink"><span id="bcrWsName">...</span></a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">TODO</li>
                        </ol>
                    </nav>

                    <!-- 헤더 -->
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h2 class="mb-0"><i class="bi bi-check2-square text-primary"></i> TODO 리스트</h2>
                    </div>

                    <!-- 컨트롤 바: 정렬/필터/선택 토글/일괄작업/내보내기 -->
                    <div class="d-flex flex-wrap gap-2 align-items-center mb-3" id="todoControlBar">
                        <!-- 정렬 -->
                        <div class="dropdown">
                            <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" id="todoSortBtn">
                                <i class="bi bi-sort-down"></i> 정렬
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item todo-sort-item active" href="#" data-sort="created_asc">오래된 순</a></li>
                                <li><a class="dropdown-item todo-sort-item" href="#" data-sort="created_desc">최신 순</a></li>
                            </ul>
                        </div>
                        <!-- 필터 -->
                        <div class="dropdown">
                            <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" id="todoFilterBtn">
                                <i class="bi bi-funnel"></i> 필터
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item todo-filter-item active" href="#" data-filter="">전체</a></li>
                                <li><a class="dropdown-item todo-filter-item" href="#" data-filter="unchecked">미완료</a></li>
                                <li><a class="dropdown-item todo-filter-item" href="#" data-filter="checked">완료</a></li>
                            </ul>
                        </div>
                        <!-- 선택 토글 -->
                        <button type="button" id="todoSelectToggle" class="btn btn-sm btn-outline-secondary d-none" aria-pressed="false">
                            <i class="bi bi-check2-square"></i> 선택
                        </button>
                        <!-- 일괄 작업 바 (선택 모드 + 선택 시 노출) -->
                        <div id="todoBulkBar" class="d-none d-flex gap-1 align-items-center">
                            <span id="todoBulkCount" class="badge bg-secondary"></span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.todoCopy('selected')">
                                <i class="bi bi-clipboard"></i> 복사하기
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-warning" id="todoBulkArchiveBtn" onclick="window.todoBulkAction('archive')">
                                <i class="bi bi-archive"></i> 보관
                            </button>
                        </div>
                        <!-- 전체 복사하기 -->
                        <button type="button" class="btn btn-sm btn-outline-secondary ms-auto" onclick="window.todoCopy('all')">
                            <i class="bi bi-clipboard"></i> 전체 복사하기
                        </button>
                    </div>

                    <!-- 추가 영역 (canWrite 시 노출) -->
                    <div id="todoAddArea" class="d-none mb-3">
                        <div class="input-group">
                            <input type="text" id="todoAddInput" class="form-control" placeholder="할 일을 입력하고 Enter" maxlength="2000" autocomplete="off">
                            <button type="button" class="btn btn-wiki" onclick="window.addTodo()">
                                <i class="bi bi-plus-lg"></i> 추가
                            </button>
                        </div>
                    </div>

                    <!-- TODO 목록 -->
                    <div id="todoList"></div>

                    <!-- 보관된 항목 섹션 -->
                    <div id="todoArchivedSection" class="mt-4 d-none">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <button type="button" class="btn btn-sm btn-link text-muted p-0 d-flex align-items-center gap-1"
                                    id="todoArchivedToggle" onclick="window.todoToggleArchived()">
                                <i class="bi bi-chevron-right" id="todoArchivedChevron"></i>
                                <span>보관된 항목</span>
                                <span id="todoArchivedBadge" class="badge bg-secondary ms-1 d-none"></span>
                            </button>
                            <!-- 보관 섹션 선택 토글 (쓰기 권한, 섹션 열림 시 표시) -->
                            <button type="button" id="todoArchivedSelectToggle" class="btn btn-sm btn-outline-secondary d-none" aria-pressed="false">
                                <i class="bi bi-check2-square"></i> 선택
                            </button>
                        </div>
                        <!-- 보관 섹션 일괄 작업 바 -->
                        <div id="todoArchivedBulkBar" class="d-none d-flex gap-1 align-items-center mt-2">
                            <span id="todoArchivedBulkCount" class="badge bg-secondary"></span>
                            <button type="button" class="btn btn-sm btn-outline-warning" onclick="window.archivedBulkAction('unarchive')">
                                <i class="bi bi-archive-fill"></i> 보관 해제
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="window.archivedBulkAction('delete')">
                                <i class="bi bi-trash"></i> 삭제
                            </button>
                        </div>
                        <div id="todoArchivedList" class="d-none mt-2"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/ws-todo.js" is:inline></script>
    </Fragment>
</BaseLayout>
