---
// 워크스페이스 미디어 관리 셸 (/ws/:wslug/media).
// wslug 는 클라이언트(ws-media.ts)가 location.pathname 에서 파싱한다.
// ws-files.astro / ws-settings.astro 와 동일한 구조를 따른다.
// 미디어 목록 조회·삭제(canWrite) + 미참조 미디어 가비지 컬렉터(canManage, 설정에서 이관)를 제공한다.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/ws-media.html" title="미디어 - CloudWiki">
    <Fragment slot="head">
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <div class="wiki-article">

                <!-- 툴바: 브레드크럼 -->
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item" id="bcrWs">
                                <a href="#" id="bcrWsLink"><span id="bcrWsName">...</span></a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">미디어</li>
                        </ol>
                    </nav>
                    <a href="#" class="btn btn-wiki-outline btn-sm" id="backToWsBtn"><i class="bi bi-arrow-left"></i> 대시보드</a>
                </div>

                <!-- 로딩 -->
                <div id="wsMediaLoading" class="wiki-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>불러오는 중...</span>
                </div>

                <!-- 오류 -->
                <div id="wsMediaError" class="d-none">
                    <div class="empty-state">
                        <i class="empty-state-icon bi bi-exclamation-triangle" aria-hidden="true"></i>
                        <p class="empty-state-title" id="wsMediaErrorTitle">미디어를 불러올 수 없습니다</p>
                        <p class="empty-state-text">존재하지 않거나 접근 권한이 없는 워크스페이스입니다.</p>
                        <div class="empty-state-cta">
                            <a href="/workspaces" class="btn btn-wiki btn-sm"><i class="bi bi-arrow-left"></i> 내 워크스페이스로</a>
                        </div>
                    </div>
                </div>

                <!-- 본문 (로드 완료 후 노출) -->
                <div id="wsMediaContent" class="d-none">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h2 class="mb-0"><i class="bi bi-image"></i> <span id="wsMediaTitle">미디어</span></h2>
                    </div>

                    <!-- 미디어 가비지 컬렉터 (canManage 만 노출) -->
                    <div class="card mb-4 d-none" id="gcCard">
                        <div class="card-header"><i class="bi bi-trash3"></i> 미디어 정리</div>
                        <div class="card-body">
                            <p class="text-muted small">어떤 문서에서도 참조하지 않는 미디어를 찾아 삭제합니다.</p>
                            <div class="d-flex gap-2 mb-3 flex-wrap">
                                <button type="button" class="btn btn-wiki-outline btn-sm" onclick="window.scanGc()">
                                    <i class="bi bi-search"></i> 미참조 미디어 검색
                                </button>
                                <button type="button" class="btn btn-wiki btn-wiki-danger btn-sm d-none" id="gcDeleteSelectedBtn" onclick="window.deleteGcSelected()">
                                    <i class="bi bi-trash"></i> 선택 삭제
                                </button>
                                <button type="button" class="btn btn-wiki btn-wiki-danger btn-sm d-none" id="gcDeleteAllBtn" onclick="window.deleteGcAll()">
                                    <i class="bi bi-trash3"></i> 전체 삭제
                                </button>
                            </div>
                            <div id="gcList"></div>
                        </div>
                    </div>

                    <!-- 미디어 목록 -->
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span class="fw-semibold"><i class="bi bi-images"></i> 미디어 목록</span>
                                <div class="d-flex gap-2 flex-wrap">
                                    <select id="mediaSortSelect" class="form-select form-select-sm" style="width:auto;" onchange="window.changeMediaSort()">
                                        <option value="date_desc">업로드 최신순</option>
                                        <option value="date_asc">업로드 오래된순</option>
                                        <option value="name_asc">파일명 A-Z</option>
                                        <option value="name_desc">파일명 Z-A</option>
                                        <option value="size_desc">파일 크기 큰순</option>
                                        <option value="size_asc">파일 크기 작은순</option>
                                    </select>
                                    <input type="text" id="mediaSearchInput" class="form-control form-control-sm" placeholder="파일명 검색..." style="width:220px;" autocomplete="off" oninput="window.searchMedia()" />
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="mediaList"></div>
                            <nav id="mediaPager" class="d-flex justify-content-center mt-2"></nav>
                            <div id="mediaTotalInfo" class="text-muted small text-center mt-2"></div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/ws-media.js" is:inline></script>
    </Fragment>
</BaseLayout>
