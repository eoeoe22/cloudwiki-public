---
// 워크스페이스 문서 편집 이력(리비전) 셸 (/ws/:wslug/w/:slug?mode=revisions).
// 전역 위키 리비전 페이지(revisions.astro)의 목록/보기/비교/되돌리기 마커를 그대로 계승해
// 동일한 화면을 워크스페이스 컨텍스트로 보여준다. 트렌딩/최근변경 사이드바(전역 위키 전용)는
// 제외하고 워크스페이스 브레드크럼만 둔다. wslug/slug 는 클라이언트(ws-revisions.ts)가 파싱한다.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/ws-revisions.html" title="편집 이력 - CloudWiki">
    <Fragment slot="head">
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
        <link rel="stylesheet" href="/render.css" />
        <link rel="stylesheet" href="/css/diff.css" />
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout">
        <div class="wiki-container">
            <!-- 워크스페이스 브레드크럼 -->
            <nav class="mb-3 small" aria-label="breadcrumb">
                <a href="/workspaces" class="text-decoration-none"><i class="bi bi-grid"></i> 워크스페이스</a>
                <span class="text-muted mx-1">/</span>
                <a href="#" id="wsRevCrumbWs" class="text-decoration-none">워크스페이스</a>
            </nav>

            <!-- 로딩 -->
            <div id="loading" class="wiki-loading">
                <div class="spinner-border text-primary" role="status"></div>
                <span>불러오는 중...</span>
            </div>

            <!-- 리비전 본문 보기 -->
            <div id="revisionViewPage" class="d-none">
                <div class="alert alert-warning py-2 px-3 mb-0 d-flex align-items-center justify-content-between"
                    style="position: sticky; top: 0; z-index: 100; border-radius: 0; border-left: none; border-right: none; margin-left: calc(-1 * var(--wiki-container-padding, 1.5rem)); margin-right: calc(-1 * var(--wiki-container-padding, 1.5rem));">
                    <span><i class="bi bi-clock-history me-2"></i><strong id="revisionViewLabel"></strong></span>
                    <div class="d-flex gap-2">
                        <button id="rawViewBtn" class="btn btn-sm btn-outline-secondary btn-icon-collapse" onclick="toggleRawView()">
                            <i class="bi bi-code"></i><span class="btn-collapse-text"> Raw</span>
                        </button>
                        <button class="btn btn-sm btn-warning btn-icon-collapse" onclick="backToRevisions()">
                            <i class="bi bi-arrow-left"></i><span class="btn-collapse-text"> 목록으로</span>
                        </button>
                    </div>
                </div>
                <div class="wiki-article">
                    <h1 class="wiki-article-title" id="revisionViewTitle"></h1>
                    <div class="wiki-content" id="revisionViewContent"></div>
                </div>
            </div>

            <!-- 리비전 목록 -->
            <div id="revisionsPage" class="d-none">
                <div class="wiki-article" style="width: 100%; max-width: 100vw; overflow-x: hidden;">
                    <h2 class="text-break"><i class="bi bi-clock-history"></i> 편집 이력: <span id="revPageTitle"></span></h2>
                    <div class="table-responsive"
                        style="width: 100%; max-width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
                        <div class="revision-list" id="revisionsList" style="min-width: 800px; width: max-content;"></div>
                    </div>
                    <nav id="revisionsPagination" class="mt-3 d-none" aria-label="편집 이력 페이지네이션">
                        <ul class="pagination justify-content-center flex-wrap" id="revisionsPaginationList"></ul>
                    </nav>
                    <a id="revBackLink" href="#" class="btn btn-wiki-outline mt-3">
                        <i class="bi bi-arrow-left"></i> 문서로 돌아가기
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/render.js" is:inline></script>
        <script type="module" src="/dist/diff.js" is:inline></script>
        <script type="module" src="/dist/ws-revisions.js" is:inline></script>
    </Fragment>
</BaseLayout>
