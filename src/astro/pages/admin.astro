---
// 관리자 콘솔 셸. 기존 public/admin.html 과 동일한 마커/구조를 유지하되,
// header/footer 를 빌드 타임에 컴포넌트로 인라인한다(런타임 placeholder 주입 불필요).
// 요청별 데이터가 없어(라우트에서 권한 게이트만 수행) fetchAssetHtml 로 순수 정적 서빙된다.
// base CDN 은 BaseLayout 이 PAGE_BUNDLES['/admin.html']=['base'] 기준으로 빌드 타임에 인라인(베이킹).
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout pagePath="/admin.html" title="관리자 콘솔 - CloudWiki">
    <Fragment slot="head">
        <link rel="stylesheet" href="/css/admin.css" />
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="admin-layout">
      <!-- ── 왼쪽 사이드바 (관리 메뉴) ── -->
      <aside class="admin-sidebar">
        <!-- 프로필 카드 -->
        <div class="admin-sidebar-profile-card mb-3" id="adminProfileCard" style="display: none;">
          <div class="d-flex align-items-center gap-2 mb-2">
            <div id="adminAvatarSlot" class="d-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 32px; height: 32px; overflow: hidden;">
              <i class="mdi mdi-account fs-4 text-muted"></i>
            </div>
            <div class="min-w-0 flex-grow-1">
              <div id="adminNameSlot" class="fw-bold text-truncate small" style="line-height: 1.2;">관리자</div>
              <div id="adminRoleSlot" class="small text-muted" style="font-size: 0.75rem;">-</div>
            </div>
          </div>
        </div>

        <div class="wiki-article">
          <h6 class="sidebar-title">
            <i class="bi bi-gear-fill"></i> 관리 메뉴
          </h6>
          <div class="admin-sidebar-nav">
            <a
              href="javascript:void(0)"
              class="admin-nav-item active"
              onclick="showTab('tab-dashboard')"
            >
              <i class="mdi mdi-view-dashboard-outline"></i>
              <span>대시보드</span>
            </a>
            <a
              href="javascript:void(0)"
              class="admin-nav-item"
              onclick="showTab('tab-users')"
            >
              <i class="mdi mdi-account-group-outline"></i>
              <span>회원 관리</span>
              <span id="sidebarSignupBadge" class="badge sidebar-signup-badge ms-auto" style="display: none;">0</span>
            </a>
            <a
              href="javascript:void(0)"
              class="admin-nav-item"
              onclick="showTab('tab-content')"
            >
              <i class="mdi mdi-file-document-edit-outline"></i>
              <span>콘텐츠 관리</span>
            </a>
            <a
              href="javascript:void(0)"
              class="admin-nav-item"
              onclick="showTab('tab-settings')"
            >
              <i class="mdi mdi-cog-outline"></i> <span>시스템 설정</span>
            </a>
            <a
              href="javascript:void(0)"
              class="admin-nav-item"
              onclick="showTab('tab-stats')"
            >
              <i class="mdi mdi-chart-line"></i> <span>통계 및 로그</span>
            </a>
          </div>
        </div>
      </aside>

      <!-- ── 메인 콘텐츠 영역 ── -->
      <div class="wiki-container">
        <div
          class="admin-header d-flex justify-content-between align-items-center"
        >
          <div>
            <h2 class="mb-1">
              <i class="mdi mdi-shield-account text-primary"></i> 관리자 콘솔
            </h2>
            <p class="text-muted mb-0 small">
              위키 설정을 관리합니다.
            </p>
          </div>
          <button class="btn btn-wiki-outline btn-sm" onclick="history.back()">
            <i class="mdi mdi-arrow-left"></i> 돌아가기
          </button>
        </div>

        <!-- ── 탭: 대시보드 (Dashboard) ── -->
        <div id="tab-dashboard" class="tab-pane active">
          <div class="row g-4 mb-4">
            <div class="col-md-6">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-3">
                    <i class="mdi mdi-ticket-outline text-primary"></i> 빠른
                    링크
                  </h5>
                  <div class="d-grid gap-2">
                    <a href="/tickets" class="admin-quick-action">
                      <i class="mdi mdi-ticket-confirmation-outline"></i>
                      <span>티켓 문의</span>
                    </a>
                    <a href="/admin-media" class="admin-quick-action">
                      <i class="mdi mdi-image-multiple-outline"></i>
                      <span>이미지 관리 도구</span>
                    </a>
                    <a href="/admin-bulk-manage" class="admin-quick-action" id="bulkManageQuickLink" style="display: none">
                      <i class="mdi mdi-file-document-multiple-outline"></i>
                      <span>문서 대량 관리 (최고 관리자)</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card shadow-sm border-0 h-100">
                <div
                  class="card-body text-center d-flex flex-column justify-content-center"
                >
                  <h6 class="text-muted mb-2">통계 확인</h6>
                  <button
                    class="btn btn-wiki btn-lg"
                    onclick="
                      showTab('tab-stats');
                      loadAnalyticsDashboard();
                    "
                  >
                    <i class="mdi mdi-chart-box-outline"></i> 통계 대시보드 열기
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div
            class="card shadow-sm border-0 mb-4"
            id="analyticsSummaryCard"
            style="display: none"
          >
            <div class="card-header py-3">
              <h5 class="mb-0">주요 통계 요약 (최근 7일)</h5>
            </div>
            <div class="card-body">
              <div class="row g-3 text-center">
                <div class="col-6 col-md-3">
                  <div class="p-3 rounded-3 dash-stat-box">
                    <div class="text-muted small">총 페이지뷰</div>
                    <div class="fs-4 fw-bold text-primary" id="dashTotalViews">
                      -
                    </div>
                  </div>
                </div>
                <div class="col-6 col-md-3">
                  <div class="p-3 rounded-3 dash-stat-box">
                    <div class="text-muted small">접속 국가</div>
                    <div class="fs-4 fw-bold text-success" id="dashCountries">
                      -
                    </div>
                  </div>
                </div>
                <div class="col-12 col-md-6">
                  <div id="dashDailyChart" style="height: 60px"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── 탭: 회원 관리 (Users) ── -->
        <div id="tab-users" class="tab-pane">
          <div
            id="signupRequestsCard"
            class="card shadow-sm border-0 mb-4"
            style="display: none"
          >
            <div class="card-header py-3">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                  가입 신청 관리
                  <span
                    class="badge bg-warning text-dark ms-2"
                    id="signupRequestsCount"
                    style="display: none"
                    >0</span
                  >
                </h5>
                <span class="badge bg-info">승인제 운영 중</span>
              </div>
            </div>
            <div class="card-body">
              <div class="d-flex flex-wrap gap-2 mb-3">
                <select
                  id="signupStatusFilter"
                  class="form-select form-select-sm"
                  style="width: auto"
                >
                  <option value="pending">대기 중</option>
                  <option value="approved">승인됨</option>
                  <option value="rejected">거절됨</option>
                  <option value="blocked">차단됨</option>
                  <option value="all">모두 보기</option>
                </select>
                <button
                  class="btn btn-sm btn-primary"
                  onclick="loadSignupRequests()"
                >
                  필터 적용
                </button>
              </div>
              <div class="table-responsive">
                <table class="table table-hover text-nowrap mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>프로필</th>
                      <th>표시명</th>
                      <th>이메일</th>
                      <th>상태</th>
                      <th>액션</th>
                    </tr>
                  </thead>
                  <tbody id="signupRequestsBody"></tbody>
                </table>
              </div>
              <div
                id="signupRequestsLoadMore"
                class="text-center py-3"
                style="display: none"
              >
                <button
                  class="btn btn-outline-secondary btn-sm"
                  onclick="loadMoreSignupRequests()"
                >
                  더 불러오기
                </button>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0">
            <div class="card-header py-3">
              <h5 class="mb-0">유저 목록 및 권한 관리</h5>
            </div>
            <div class="card-body">
              <div class="d-flex flex-wrap gap-2 mb-3">
                <input
                  type="text"
                  id="userSearchInput"
                  class="form-control form-control-sm"
                  placeholder="이름/이메일 검색"
                  style="max-width: 180px"
                />
                <select
                  id="userRoleFilter"
                  class="form-select form-select-sm"
                  style="width: auto"
                >
                  <option value="all">모든 권한</option>
                  <option value="super_admin">최고 관리자</option>
                  <option value="admin">관리자</option>
                  <option value="discussion_manager">토론 관리자</option>
                  <option value="user">일반 유저</option>
                </select>
                <button class="btn btn-sm btn-primary" onclick="searchUsers()">
                  검색
                </button>
              </div>
              <div class="table-responsive">
                <table class="table table-hover user-table text-nowrap mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>프로필</th>
                      <th>이름</th>
                      <th>권한</th>
                      <th>상태</th>
                      <th>가입일</th>
                      <th>관리</th>
                    </tr>
                  </thead>
                  <tbody id="userTableBody"></tbody>
                </table>
              </div>
              <div
                id="userLoadMoreWrapper"
                class="text-center py-3"
                style="display: none"
              >
                <button
                  class="btn btn-outline-secondary btn-sm"
                  onclick="loadMoreUsers()"
                >
                  더 불러오기
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- ── 탭: 콘텐츠 관리 (Content) ── -->
        <div id="tab-content" class="tab-pane">
          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3">
              <h5 class="mb-0">삭제된 문서 관리 (Soft Delete)</h5>
            </div>
            <div class="card-body">
              <div class="d-flex flex-wrap gap-2 mb-3">
                <input
                  type="text"
                  id="deletedPagesSearch"
                  class="form-control form-control-sm"
                  placeholder="문서명/제목 검색"
                  style="max-width: 240px"
                  onkeydown="if (event.key === 'Enter') searchDeletedPages();"
                />
                <button
                  class="btn btn-sm btn-primary"
                  onclick="searchDeletedPages()"
                >
                  검색
                </button>
                <button
                  class="btn btn-sm btn-outline-secondary"
                  onclick="resetDeletedPagesSearch()"
                >
                  초기화
                </button>
                <span
                  class="ms-auto small text-muted align-self-center"
                  id="deletedPagesTotal"
                ></span>
              </div>
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>문서명 (Slug)</th>
                      <th>삭제일시</th>
                      <th>액션</th>
                    </tr>
                  </thead>
                  <tbody id="deletedPagesBody"></tbody>
                </table>
              </div>
              <nav
                id="deletedPagesPagination"
                class="mt-3"
                aria-label="삭제된 문서 페이지 이동"
              ></nav>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
              <h5 class="mb-0">카테고리 ACL</h5>
              <select id="categoryAclSort" class="form-select form-select-sm" style="width: auto;">
                <option value="name_asc">이름 ↑</option>
                <option value="name_desc">이름 ↓</option>
                <option value="pages_desc">문서 수 많은순</option>
                <option value="created_desc">최근 등록순</option>
              </select>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-3">
                카테고리에 편집 ACL 템플릿을 매달면, 그 카테고리가 문서에 적용될
                때 페이지의 <code>edit_acl</code> 이 모드(덮어쓰기/합치기/무시)에 따라
                갱신됩니다. <b>관리자 전용</b> 플래그를 켜면 비관리자는 해당
                카테고리를 적용할 수 없습니다 (구 "관리자 전용 카테고리" 와 동일 효과).
                카테고리를 클릭하면 해당 카테고리 문서로 이동합니다.
              </p>
              <div
                id="categoryAclSummary"
                class="list-group list-group-flush border rounded"
              ></div>
              <nav
                id="categoryAclPagination"
                class="mt-2"
                aria-label="카테고리 ACL 페이지 이동"
              ></nav>
            </div>
          </div>

          <!-- ── 컬러 팔레트 관리 ── -->
          <div class="card shadow-sm border-0 mb-4" id="paletteManagementSection">
            <div class="card-header py-3">
              <h5 class="mb-0">컬러 팔레트 관리</h5>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-3">
                본문에서 <code>{'{palette:이름}'}</code> 로 사용할 수 있는
                커스텀 컬러 팔레트를 관리합니다. 배경색을 지정하면 휘도에 따라
                글씨색이 자동 계산되며(수동 변경 가능), 다크모드에서 다른 색을
                쓰려면 별도 색상 토글을 켜세요. 기본 색상인 프리셋
                (<code>primary</code>·<code>secondary</code>·<code>success</code>·<code>info</code>·<code>warning</code>·<code>danger</code>·<code>muted</code>)
                는 사용할 수 없습니다.
              </p>

              <!-- ── 새 팔레트 추가 폼 ── -->
              <div class="admin-subpanel mb-3" id="paletteForm">
                <div class="palette-form-header">
                  <h6 class="mb-0" id="paletteFormTitle">새 팔레트 추가</h6>
                  <div class="palette-form-actions">
                    <button
                      class="btn btn-wiki-outline btn-sm"
                      type="button"
                      id="paletteFormReset"
                      style="display: none"
                    >
                      취소
                    </button>
                    <button
                      class="btn btn-primary btn-sm"
                      type="button"
                      id="paletteFormSubmit"
                    >
                      저장
                    </button>
                  </div>
                </div>

                <div class="palette-form-name mt-2">
                  <label class="form-label small mb-1" for="paletteNameInput">이름</label>
                  <input
                    type="text"
                    id="paletteNameInput"
                    class="form-control"
                    placeholder="팔레트 이름"
                    maxlength="64"
                    autocomplete="off"
                  />
                  <div
                    class="text-danger small mt-1"
                    id="paletteNameError"
                    style="display: none"
                  ></div>
                </div>

                <!-- Light 변형 -->
                <div class="palette-variant-section mt-3" data-variant="light">
                  <div class="palette-variant-header">
                    <i class="mdi mdi-white-balance-sunny"></i>
                    <span>라이트 모드</span>
                  </div>
                  <div class="palette-color-pair">
                    <div class="palette-color-block" data-channel="light.bg">
                      <div class="palette-color-block-header">
                        <span class="palette-color-block-label">배경색</span>
                      </div>
                      <div
                        id="paletteLightBgSwatches"
                        class="palette-swatches-grid mb-2"
                      ></div>
                      <canvas
                        id="paletteLightBgCanvas"
                        class="palette-sv-canvas"
                        width="220"
                        height="120"
                      ></canvas>
                      <canvas
                        id="paletteLightBgHue"
                        class="palette-hue-canvas mt-2"
                        width="220"
                        height="16"
                      ></canvas>
                      <input
                        type="text"
                        id="paletteLightBgHex"
                        class="form-control form-control-sm font-monospace mt-2"
                        value="#0D65F5"
                        maxlength="9"
                      />
                    </div>
                    <div class="palette-color-block" data-channel="light.color">
                      <div class="palette-color-block-header">
                        <span class="palette-color-block-label">글씨색</span>
                        <span class="form-check form-switch mb-0 palette-auto-toggle">
                          <input
                            class="form-check-input"
                            type="checkbox"
                            id="paletteLightAuto"
                            checked
                          />
                          <label class="form-check-label small" for="paletteLightAuto">자동 대비</label>
                        </span>
                      </div>
                      <div
                        id="paletteLightColorSwatches"
                        class="palette-swatches-grid mb-2"
                      ></div>
                      <canvas
                        id="paletteLightColorCanvas"
                        class="palette-sv-canvas"
                        width="220"
                        height="120"
                      ></canvas>
                      <canvas
                        id="paletteLightColorHue"
                        class="palette-hue-canvas mt-2"
                        width="220"
                        height="16"
                      ></canvas>
                      <input
                        type="text"
                        id="paletteLightColorHex"
                        class="form-control form-control-sm font-monospace mt-2"
                        value="#FFFFFF"
                        maxlength="9"
                      />
                    </div>
                  </div>
                </div>

                <div class="form-check form-switch mt-3">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="paletteHasDark"
                  />
                  <label class="form-check-label small" for="paletteHasDark">
                    다크모드 별도 색상 지정
                  </label>
                </div>

                <!-- Dark 변형 -->
                <div
                  class="palette-variant-section mt-3"
                  id="paletteDarkRow"
                  data-variant="dark"
                  style="display: none"
                >
                  <div class="palette-variant-header">
                    <i class="mdi mdi-weather-night"></i>
                    <span>다크 모드</span>
                  </div>
                  <div class="palette-color-pair">
                    <div class="palette-color-block" data-channel="dark.bg">
                      <div class="palette-color-block-header">
                        <span class="palette-color-block-label">배경색</span>
                      </div>
                      <div
                        id="paletteDarkBgSwatches"
                        class="palette-swatches-grid mb-2"
                      ></div>
                      <canvas
                        id="paletteDarkBgCanvas"
                        class="palette-sv-canvas"
                        width="220"
                        height="120"
                      ></canvas>
                      <canvas
                        id="paletteDarkBgHue"
                        class="palette-hue-canvas mt-2"
                        width="220"
                        height="16"
                      ></canvas>
                      <input
                        type="text"
                        id="paletteDarkBgHex"
                        class="form-control form-control-sm font-monospace mt-2"
                        value="#0D65F5"
                        maxlength="9"
                      />
                    </div>
                    <div class="palette-color-block" data-channel="dark.color">
                      <div class="palette-color-block-header">
                        <span class="palette-color-block-label">글씨색</span>
                        <span class="form-check form-switch mb-0 palette-auto-toggle">
                          <input
                            class="form-check-input"
                            type="checkbox"
                            id="paletteDarkAuto"
                            checked
                          />
                          <label class="form-check-label small" for="paletteDarkAuto">자동 대비</label>
                        </span>
                      </div>
                      <div
                        id="paletteDarkColorSwatches"
                        class="palette-swatches-grid mb-2"
                      ></div>
                      <canvas
                        id="paletteDarkColorCanvas"
                        class="palette-sv-canvas"
                        width="220"
                        height="120"
                      ></canvas>
                      <canvas
                        id="paletteDarkColorHue"
                        class="palette-hue-canvas mt-2"
                        width="220"
                        height="16"
                      ></canvas>
                      <input
                        type="text"
                        id="paletteDarkColorHex"
                        class="form-control form-control-sm font-monospace mt-2"
                        value="#FFFFFF"
                        maxlength="9"
                      />
                    </div>
                  </div>
                </div>

                <!-- 프리뷰 -->
                <div class="palette-preview-row mt-3">
                  <span class="text-muted small me-2">프리뷰:</span>
                  <span class="palette-preview-badge" id="paletteLightPreview">Light</span>
                  <span class="palette-preview-badge palette-preview-dark" id="paletteDarkPreview" style="display: none">Dark</span>
                </div>
              </div>

              <!-- ── 팔레트 목록 ── -->
              <div
                id="paletteList"
                class="list-group list-group-flush border rounded"
              >
                <div class="p-3 text-center text-muted small">불러오는 중…</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── 탭: 시스템 설정 (Settings) ── -->
        <div id="tab-settings" class="tab-pane">
          <!-- ── 사이트 공지 ── -->
          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3">
              <h5 class="mb-0">사이트 공지</h5>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-3">
                여러 개의 공지를 발행하면 헤더에 위에서 아래 순서로 쌓입니다.
                블로그 포스트 페이지의 "공지로 발행" 버튼은 그대로 사용
                가능하며, 여기서 추가하는 공지는 외부 링크 또는 링크 없는 텍스트
                배너로 발행됩니다.
              </p>
              <!-- 신규 공지 발행 폼 -->
              <div class="admin-subpanel mb-3">
                <h6 class="mb-2">새 공지 발행</h6>
                <div class="row g-2">
                  <div class="col-12 col-md-5">
                    <label class="form-label small mb-1">제목</label>
                    <input
                      type="text"
                      id="annNewTitle"
                      class="form-control form-control-sm"
                      maxlength="200"
                      placeholder="공지 제목"
                    />
                  </div>
                  <div class="col-12 col-md-5">
                    <label class="form-label small mb-1">링크 URL (선택)</label>
                    <input
                      type="text"
                      id="annNewUrl"
                      class="form-control form-control-sm"
                      placeholder="https://... 또는 /blog/123 / 비우면 텍스트 전용"
                    />
                  </div>
                  <div class="col-12 col-md-2">
                    <label class="form-label small mb-1">아이콘</label>
                    <div class="d-flex gap-1 align-items-center">
                      <button
                        type="button"
                        id="annNewIconBtn"
                        class="btn btn-sm btn-outline-secondary flex-grow-1"
                      >
                        <i id="annNewIconPreview" class="mdi mdi-bullhorn"></i>
                        <span class="ms-1" id="annNewIconLabel">기본</span>
                      </button>
                      <button
                        type="button"
                        id="annNewIconClearBtn"
                        class="btn btn-sm btn-outline-secondary"
                        title="아이콘 초기화"
                      >
                        <i class="bi bi-x"></i>
                      </button>
                    </div>
                  </div>
                </div>
                <div class="mt-2 text-end">
                  <button
                    type="button"
                    id="annNewSubmit"
                    class="btn btn-wiki btn-sm"
                  >
                    <i class="mdi mdi-bullhorn me-1"></i>공지 발행
                  </button>
                </div>
              </div>
              <!-- 현재 공지 목록 -->
              <div class="table-responsive">
                <table
                  class="table table-sm align-middle mb-0"
                  id="announcementsTable"
                >
                  <thead>
                    <tr>
                      <th style="width: 60px">아이콘</th>
                      <th>제목</th>
                      <th style="width: 200px">링크</th>
                      <th style="width: 180px">발행 시각</th>
                      <th style="width: 160px" class="text-end">관리</th>
                    </tr>
                  </thead>
                  <tbody id="announcementsTbody">
                    <tr>
                      <td colspan="5" class="text-center text-muted">
                        불러오는 중...
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 공지 수정 모달 -->
          <div
            class="modal fade"
            id="announcementEditModal"
            tabindex="-1"
            aria-hidden="true"
          >
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title">
                    <i class="mdi mdi-pencil me-2"></i>공지 수정
                  </h5>
                  <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                  ></button>
                </div>
                <div class="modal-body">
                  <p class="text-muted small mb-3">
                    제목과 아이콘만 변경할 수 있습니다. 발행 시각은 갱신되지
                    않으며 Discord 알림도 발송되지 않습니다.
                  </p>
                  <input type="hidden" id="annEditId" />
                  <div class="mb-3">
                    <label class="form-label">제목</label>
                    <input
                      type="text"
                      id="annEditTitle"
                      class="form-control"
                      maxlength="200"
                    />
                  </div>
                  <div class="mb-3">
                    <label class="form-label">아이콘</label>
                    <div class="d-flex gap-2 align-items-center">
                      <button
                        type="button"
                        id="annEditIconBtn"
                        class="btn btn-outline-secondary"
                      >
                        <i id="annEditIconPreview" class="mdi mdi-bullhorn"></i>
                        <span class="ms-1" id="annEditIconLabel">기본</span>
                      </button>
                      <button
                        type="button"
                        id="annEditIconClearBtn"
                        class="btn btn-outline-secondary"
                        title="아이콘 초기화"
                      >
                        <i class="bi bi-x"></i>
                      </button>
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button
                    type="button"
                    class="btn btn-wiki-outline"
                    data-bs-dismiss="modal"
                  >
                    취소
                  </button>
                  <button type="button" id="annEditSubmit" class="btn btn-wiki">
                    저장
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3">
              <h5 class="mb-0">위키 운영 정책</h5>
            </div>
            <div class="card-body">
              <h6 class="fw-bold mb-3">표시명 변경 정책</h6>
              <div class="mb-4">
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="namechangePolicy"
                    id="namechangeUnlimited"
                    value="0"
                  />
                  <label class="form-check-label" for="namechangeUnlimited"
                    >무제한 허용</label
                  >
                </div>
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="namechangePolicy"
                    id="namechangeDisabled"
                    value="-1"
                  />
                  <label class="form-check-label" for="namechangeDisabled"
                    >변경 불허</label
                  >
                </div>
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="namechangePolicy"
                    id="namechangeCooldown"
                    value="custom"
                  />
                  <label class="form-check-label" for="namechangeCooldown"
                    >일 단위 제한</label
                  >
                </div>
                <div
                  class="ms-4 mt-2"
                  id="cooldownDaysWrapper"
                  style="display: none"
                >
                  <div class="input-group" style="max-width: 150px">
                    <input
                      type="number"
                      class="form-control"
                      id="cooldownDaysInput"
                      min="1"
                      value="30"
                    />
                    <span class="input-group-text">일</span>
                  </div>
                </div>
              </div>

              <hr />
              <h6 class="fw-bold mb-3">개인 쪽지 및 가입</h6>
              <div class="form-check form-switch mb-3">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="allowDmSwitch"
                />
                <label class="form-check-label" for="allowDmSwitch"
                  >개인 쪽지 허용</label
                >
              </div>
              <div class="mb-4">
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="signupPolicy"
                    id="signupPolicyOpen"
                    value="open"
                  />
                  <label class="form-check-label" for="signupPolicyOpen"
                    >자유 가입</label
                  >
                </div>
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="signupPolicy"
                    id="signupPolicyApproval"
                    value="approval"
                  />
                  <label class="form-check-label" for="signupPolicyApproval"
                    >관리자 승인제</label
                  >
                </div>
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="signupPolicy"
                    id="signupPolicyBlocked"
                    value="blocked"
                  />
                  <label class="form-check-label" for="signupPolicyBlocked"
                    >차단 (가입 불가)</label
                  >
                </div>
              </div>

              <hr />
              <h6 class="fw-bold mb-3">편집 ACL 전역 설정</h6>
              <div class="mb-4">
                <label for="editAclMinAgeInput" class="form-label">
                  편집 ACL <b>가입 N일 이상</b> 임계값
                </label>
                <div class="input-group" style="max-width: 220px">
                  <input
                    type="number"
                    class="form-control"
                    id="editAclMinAgeInput"
                    min="0"
                    max="36500"
                    value="0"
                  />
                  <span class="input-group-text">일</span>
                </div>
                <small class="text-muted d-block mt-1">
                  pages.edit_acl 의 <code>aged</code> 플래그가 참조하는 전역 임계값. 0이면 가입 즉시 통과(=비활성).
                </small>
              </div>

              <hr />
              <h6 class="fw-bold mb-3">편집 요청</h6>
              <div class="mb-4">
                <small class="text-muted d-block">
                  ACL 미달 사용자의 편집을 즉시 반영하지 않고 편집 요청으로 보류해, 검토자(관리자·신뢰 사용자)가
                  문서 페이지에서 승인/반려하는 기능입니다. 이 토글은 배포 설정(<code>wrangler.toml</code> 의
                  <code>EDIT_REQUEST_ENABLED</code>)으로 이전되었습니다. <code>edit_acl_min_age_days</code> 가
                  0 보다 커야 보류가 발생합니다.
                </small>
              </div>

              <button
                class="btn btn-wiki w-100 mb-4"
                onclick="saveWikiSettings()"
              >
                <i class="mdi mdi-content-save-outline"></i> 설정 저장
              </button>

              <hr />
              <h6 class="fw-bold mb-3">MCP 서버 설정</h6>
              <div class="mb-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span id="mcpModeDisplay" class="badge bg-secondary"
                    >확인 중...</span
                  >
                  <span class="text-muted small"
                    >wrangler.toml의 MCP_MODE 환경변수로 관리됩니다.</span
                  >
                </div>
                <div
                  id="mcpServerUrlBox"
                  class="admin-info-box small"
                  style="display: none"
                >
                  <div class="fw-bold mb-2">
                    MCP 서버 주소
                  </div>
                  <div class="input-group input-group-sm mb-3">
                    <input
                      type="text"
                      id="mcpServerUrlInput"
                      class="form-control font-monospace"
                      readonly
                    />
                    <button
                      class="btn btn-wiki"
                      onclick="copyMcpUrl('mcpServerUrlInput')"
                    >
                      <i class="mdi mdi-content-copy"></i> 복사
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── 탭: 통계 및 로그 (Stats) ── -->
        <div id="tab-stats" class="tab-pane">
          <div class="card shadow-sm border-0 mb-4">
            <div
              class="card-header py-3 d-flex justify-content-between align-items-center"
            >
              <h5 class="mb-0">트래픽 통계</h5>
              <button
                class="btn btn-sm btn-outline-secondary"
                onclick="refreshAnalytics()"
              >
                새로고침
              </button>
            </div>
            <div class="card-body">
              <div id="analyticsContainer">
                <div class="text-center py-5" id="analyticsLoadBtn">
                  <button
                    class="btn btn-primary"
                    onclick="loadAnalyticsDashboard()"
                  >
                    데이터 로드
                  </button>
                </div>
                <div id="analyticsRealContent" style="display: none">
                  <div
                    id="dailyChart"
                    class="mb-4"
                    style="overflow-x: auto"
                  ></div>
                  <div class="row g-3">
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-trending-up text-primary"></i> 인기 문서</h6>
                        <div id="topPagesContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-fire text-danger"></i> 트렌딩 (24h)</h6>
                        <div id="trendingContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-link-variant text-success"></i> 유입 경로</h6>
                        <div id="referrersContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-earth text-info"></i> 접속 국가</h6>
                        <div id="countriesContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-cellphone-link text-warning"></i> 기기 및 브라우저</h6>
                        <div id="devicesContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                      <div class="card h-100 border-0 bg-light-subtle shadow-sm p-3">
                        <h6 class="fw-bold border-bottom pb-2 mb-2"><i class="mdi mdi-magnify text-secondary"></i> 검색어</h6>
                        <div id="searchesContainer" class="small"></div>
                      </div>
                    </div>
                    <div class="col-12 mt-3">
                      <h6>최근 에러 (HTTP 오류)</h6>
                      <div class="table-responsive">
                        <table
                          class="table table-sm"
                          style="white-space: nowrap"
                        >
                          <thead>
                            <tr>
                              <th>경로</th>
                              <th>에러 메시지</th>
                              <th>상태 코드</th>
                              <th>발생 횟수</th>
                            </tr>
                          </thead>
                          <tbody id="errorsContainerBody"></tbody>
                        </table>
                      </div>
                    </div>
                    <div class="col-12 mt-3">
                      <h6>성능 통계 (평균 응답 속도)</h6>
                      <div
                        id="performanceContainer"
                        class="small d-flex gap-4"
                      ></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0">
            <div class="card-header py-3">
              <h5 class="mb-0">관리 활동 로그</h5>
            </div>
            <div class="card-body">
              <div class="row g-2 mb-3">
                <div class="col-sm-5">
                  <div class="input-group input-group-sm">
                    <input
                      type="text"
                      id="adminLogSearch"
                      class="form-control"
                      placeholder="관리자 또는 내용 검색"
                      onkeydown="if (event.key === 'Enter') loadAdminLogs();"
                    />
                    <button
                      class="btn btn-outline-secondary"
                      onclick="loadAdminLogs()"
                    >
                      검색
                    </button>
                  </div>
                </div>
                <div class="col-sm-4">
                  <select
                    id="adminLogType"
                    class="form-select form-select-sm"
                    onchange="loadAdminLogs()"
                  >
                    <option value="all">전체 유형</option>
                    <option value="role_change">권한 변경</option>
                    <option value="ban">차단/해제</option>
                    <option value="signup_approve">가입 승인</option>
                    <option value="signup_reject">가입 거절</option>
                    <option value="signup_block">가입 차단</option>
                    <option value="settings">설정 변경</option>
                    <option value="category_add">카테고리 추가</option>
                    <option value="category_delete">카테고리 삭제</option>
                    <option value="media_delete">미디어 삭제</option>
                    <option value="media_gc">미디어 GC</option>
                    <option value="soft_delete">문서 삭제</option>
                    <option value="hard_delete">문서 영구 삭제</option>
                    <option value="restore">문서 복원</option>
                    <option value="doc_move">문서 이동</option>
                    <option value="bulk_soft_delete">문서 대량 삭제</option>
                    <option value="bulk_hard_delete">문서 대량 영구 삭제</option>
                    <option value="bulk_move">문서 대량 이동</option>
                  </select>
                </div>
              </div>
              <div class="table-responsive admin-log-table-wrap">
                <table class="table table-hover table-sm admin-log-table">
                  <thead class="table-light">
                    <tr>
                      <th>시간</th>
                      <th>유형</th>
                      <th>내용</th>
                      <th>관리자</th>
                    </tr>
                  </thead>
                  <tbody id="adminLogBody"></tbody>
                </table>
              </div>
              <div
                class="d-flex justify-content-between align-items-center mt-2"
              >
                <span class="small text-muted" id="adminLogTotal"></span>
                <nav
                  id="adminLogPagination"
                  aria-label="관리 활동 로그 페이지 이동"
                ></nav>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- wiki-container end -->
      </div>
    <!-- admin-layout end -->

    <!-- 아이콘 피커 모달 (iconPicker.ts 모듈이 사용) — body 레벨에 두어
         Bootstrap 모달이 부모 컨테이너 stacking context 의 영향을 받지 않도록 함. -->
    <div
      class="modal fade"
      id="iconPickerModal"
      tabindex="-1"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">
              <i
                id="iconPickerTypeIcon"
                class="mdi mdi-material-design me-2"
              ></i>
              <span id="iconPickerTitle">아이콘 선택</span>
            </h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>
          <div class="modal-body">
            <div class="icon-picker-toolbar mb-2">
              <div
                class="icon-picker-tabs"
                role="tablist"
                aria-label="아이콘 라이브러리"
              >
                <button
                  type="button"
                  id="iconPickerTabMdi"
                  class="icon-picker-tab active"
                  role="tab"
                  aria-selected="true"
                >
                  <i class="mdi mdi-material-design"></i>
                  <span>MDI</span>
                </button>
                <button
                  type="button"
                  id="iconPickerTabBi"
                  class="icon-picker-tab"
                  role="tab"
                  aria-selected="false"
                >
                  <i class="bi bi-bootstrap"></i>
                  <span>Bootstrap</span>
                </button>
              </div>
              <button
                type="button"
                id="iconPickerNoneBtn"
                class="icon-picker-none-btn"
              >
                <i class="bi bi-x-lg"></i>
                <span>아이콘 없음</span>
              </button>
            </div>
            <input
              type="text"
              id="iconSearchInput"
              class="form-control mb-3"
              placeholder="아이콘 이름 검색..."
            />
            <div
              id="iconLoadingSpinner"
              class="text-center py-4"
              style="display: none"
            >
              <span class="spinner-border text-primary" role="status"></span>
              <p class="mt-2 text-muted small">아이콘 목록 로딩 중...</p>
            </div>
            <div id="iconPickerGrid" class="icon-grid-modal"></div>
            <div
              id="iconPickerEmpty"
              class="text-center text-muted py-3"
              style="display: none"
            >
              <i class="mdi mdi-magnify-close" style="font-size: 2rem"></i>
              <p class="mt-1">검색 결과가 없습니다.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── 푸터 ── -->
    <Footer />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/icon-picker.js" is:inline></script>
        <script type="module" src="/dist/admin-palettes.js" is:inline></script>
        <script type="module" src="/dist/admin.js" is:inline></script>
    </Fragment>
</BaseLayout>
