---
// 워크스페이스 문서 조회 셸 (/ws/:wslug/w/:slug). 전역 위키 문서 조회(index.astro)의
// 레이아웃·마커를 최대한 계승한다 — 브레드크럼/문서 구조 네비·목차(TOC)·역링크·읽기/Raw/
// 공유 동작이 src/client/article/* 공유 모듈을 통해 전역 위키와 동일하게 작동하도록, 같은
// DOM ID(#articlePage·#articleContent·#parentDocsNav·#tocNav·#backlinksSection 등)를 쓴다.
// 워크스페이스에 없는 기능(카테고리/주시/토론/MCP/편집요청/AI 공유)만 제거했다.
// wslug/slug 는 클라이언트(ws-doc.ts)가 location.pathname 에서 파싱한다(서버 SSR 데이터 없음).
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleFloatingTools from '../components/ArticleFloatingTools.astro';
---
<BaseLayout pagePath="/ws-doc.html" title="워크스페이스 문서 - CloudWiki">
    <Fragment slot="head">
        <link rel="stylesheet" href="/render.css" />
        <link rel="stylesheet" href="/css/wiki-nav.css" />
        <link rel="stylesheet" href="/css/presentation.css" />
        <!-- 테마 FOUC 방지: CSS 로드 후 즉시 테마 적용 -->
        <script is:inline>try{var t=localStorage.getItem('themeMode');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}</script>
    </Fragment>

    <!-- ── 네비게이션 바 ── -->
    <Header />

    <div class="wiki-layout wiki-layout-doc">
        <!-- 좌측 목차 사이드바 (LAYOUT_MODE="left-toc") -->
        <aside class="wiki-toc-sidebar d-none" id="wikiTocSidebar" aria-label="문서 목차">
            <div class="wiki-toc-sidebar-inner">
                <div class="wiki-toc-sidebar-title"><i class="bi bi-list-columns-reverse"></i> 목차</div>
                <nav class="wiki-toc-sidebar-nav" id="wikiTocSidebarNav"></nav>
            </div>
        </aside>

        <div class="wiki-container">

            <!-- 로딩 -->
            <div id="wsDocLoading" class="wiki-loading">
                <div class="spinner-border text-primary" role="status"></div>
                <span>불러오는 중...</span>
            </div>

            <!-- 빈 상태 / 오류 -->
            <div id="wsDocEmpty" class="d-none"></div>

            <!-- 문서 보기 페이지 (#articlePage — 스크롤 스파이/FAB 가시성 판정에 사용) -->
            <div id="articlePage" class="d-none">

                <!-- 워크스페이스 브레드크럼 -->
                <nav class="mb-3 small" aria-label="breadcrumb">
                    <a href="/workspaces" class="text-decoration-none"><i class="bi bi-grid"></i> 워크스페이스</a>
                    <span class="text-muted mx-1">/</span>
                    <a href="#" id="wsDocCrumbWs" class="text-decoration-none">워크스페이스</a>
                </nav>

                <div class="wiki-article">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <h1 class="wiki-article-title mb-0" id="articleTitle"></h1>
                        <!-- 문서 도구: 편집 / 공유 / 도구 드롭다운 -->
                        <div class="d-flex gap-2" id="wsDocActions"></div>
                    </div>
                    <!-- 대체 title 라벨(슬러그) -->
                    <div id="articleSlugLabel" class="wiki-article-slug-label" hidden></div>
                    <!-- 리다이렉트 안내 -->
                    <div id="redirectMessage"></div>
                    <!-- 문서 메타(수정 시각·버전) -->
                    <div class="wiki-article-meta" id="articleMeta"></div>

                    <!-- 상위/형제 문서 네비 (문서 구조 브레드크럼) -->
                    <div id="parentDocsNavWrapper" class="parent-docs-nav-wrapper">
                        <div id="parentDocsNav" class="d-none parent-docs-nav mb-0"></div>
                        <div id="parentDocsSiblings" class="d-none parent-docs-siblings"></div>
                    </div>
                    <hr id="parentDocsNavDivider" class="d-none mt-2 mb-3">

                    <!-- 목차 데이터 소스(#tocNav) — 본문 인라인 목차 카드/플로팅 패널/사이드바 클론용.
                         실제 노출은 renderWikiContent 의 인라인 카드가 담당하므로 숨겨 둔다. -->
                    <div class="accordion mb-4" id="wikiAccordion">
                        <div class="accordion-item d-none">
                            <div id="tocContainer" class="d-none">
                                <nav id="tocNav"></nav>
                            </div>
                        </div>
                    </div>

                    <!-- 본문 -->
                    <div class="wiki-content" id="articleContent"></div>

                    <!-- 본문 (Raw 보기) -->
                    <pre class="wiki-content-raw" id="articleRawContent"></pre>

                    <!-- 역링크 (본문 하단) -->
                    <div class="backlinks-section d-none" id="backlinksSection">
                        <h5><i class="bi bi-link-45deg"></i> 이 문서를 참조하는 문서</h5>
                        <div class="list-group" id="backlinksList"></div>
                    </div>
                </div>
            </div>

        </div> <!-- wiki-container end -->

        <!-- 우측 문서내 목차 사이드바 (LAYOUT_MODE="docs" 또는 "right-toc") -->
        <aside class="wiki-toc-sidebar wiki-toc-sidebar-right d-none" id="wikiTocSidebarRight" aria-label="문서 목차">
            <div class="wiki-toc-sidebar-inner">
                <nav class="wiki-toc-sidebar-nav" id="wikiTocSidebarRightNav"></nav>
            </div>
        </aside>
    </div> <!-- wiki-layout end -->

    <!-- ── 푸터 ── -->
    <Footer />

    <!-- 플로팅 목차 패널 + 스크롤 FAB (전역 위키 셸과 공유) -->
    <ArticleFloatingTools />

    <Fragment slot="scripts">
        <script type="module" src="/dist/common.js" is:inline></script>
        <script type="module" src="/dist/render.js" is:inline></script>
        <script type="module" src="/dist/render-presentation.js" is:inline></script>
        <script type="module" src="/dist/ws-doc.js" is:inline></script>
    </Fragment>
</BaseLayout>
