---
// 공통 푸터 컴포넌트. public/components/footer.html 을 단일 소스로 ?raw import 하여 인라인.
// 브랜딩 마커(.app-wiki-name)와 #custom-footer-content(env FOOTER 기반)는 빌드 타임에
// bakeComponentBranding 으로 박아넣는다 — Astro 셸은 런타임 주입 없이 즉시 서빙된다.
import raw from '../../../public/components/footer.html?raw';
import { readBranding, bakeComponentBranding } from '../../../scripts/branding.mjs';
const baked = bakeComponentBranding(raw, readBranding());
---
<Fragment set:html={baked} />
