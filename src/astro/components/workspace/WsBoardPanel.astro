---
// 워크스페이스 게시판 패널 — 목록 뷰 · 상세 뷰 (SPA 내 전환)
---
<div id="boardPanel" class="ws-panel d-none" role="tabpanel" aria-labelledby="tab-board">
    <!-- 게시글 목록 뷰 -->
    <div id="boardListView">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div><!-- 헤더 타이틀은 JS에서 주입하지 않고 탭 레이블로 대체 --></div>
            <div id="boardNewBtn" class="d-none"></div>
        </div>
        <div id="postList"></div>
        <nav aria-label="게시글 페이지" id="boardPagination" class="mt-3"></nav>
    </div>

    <!-- 게시글 상세 뷰 -->
    <div id="boardDetailView" class="d-none">
        <div class="mb-3">
            <button type="button" class="btn btn-wiki-outline btn-sm"
                    onclick="window.goList()">
                <i class="bi bi-arrow-left"></i> 목록으로
            </button>
        </div>
        <div id="postDetail"></div>
    </div>
</div>
