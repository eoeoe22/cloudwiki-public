---
// 공통 헤더 컴포넌트. public/components/header.html 을 단일 소스로 ?raw import 하여
// 빌드 타임에 인라인한다(손으로 복제하지 않음 — 비-Astro 페이지는 같은 파일을 런타임 주입으로 사용).
// 브랜딩 마커(.app-wiki-name, .wiki-logo-container)는 빌드 타임에 bakeComponentBranding 으로
// wrangler.toml 값을 박아넣어 Astro 셸이 런타임 HTMLRewriter 없이 즉시 서빙되도록 한다.
// 인라인 <script>(검색 자동완성)·onclick 핸들러는 set:html 로 원문 그대로 출력되어 정상 동작한다.
import raw from '../../../public/components/header.html?raw';
import { readBranding, bakeComponentBranding } from '../../../scripts/branding.mjs';
const baked = bakeComponentBranding(raw, readBranding());
---
<Fragment set:html={baked} />
