{
  "name": "cloudwiki",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "astro build && node scripts/copy-astro-pages.mjs && vite build",
    "build:astro": "astro build && node scripts/copy-astro-pages.mjs",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json",
    "generate:rules": "node scripts/generate-rules.mjs"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@types/node": "^25.6.0",
    "astro": "^6.4.2",
    "typescript": "^5.5.0",
    "vite": "^8.0.10",
    "wrangler": "^4.78.0"
  }
}
